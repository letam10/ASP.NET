@{
    ViewData["Title"] = "Kiểm tra email";
}
<div class="container py-5" style="margin-top:70px;">
    <div class="row justify-content-center text-center">
        <div class="col-md-6">
            <div class="card bg-card border-0 shadow-lg p-5" style="border-radius: 20px;">
                <div class="mb-4">
                    <i class="bi bi-envelope-check-fill text-success" style="font-size: 4rem;"></i>
                </div>
                <h3 class="text-primary mb-3">Email đã được gửi!</h3>
                <p class="text-secondary mb-4">
                    Nếu email tồn tại trong hệ thống, bạn sẽ sớm nhận được hướng dẫn đặt lại mật khẩu. Vui lòng kiểm tra kỹ cả hòm thư rác (Spam).
                </p>
                <div class="d-flex gap-2 justify-content-center">
                    <a class="btn btn-outline-primary px-4" asp-action="Login">
                        <i class="bi bi-arrow-left me-2"></i>Đăng nhập
                    </a>
                    <a class="btn btn-primary px-4" asp-controller="Home" asp-action="Index">Trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>
