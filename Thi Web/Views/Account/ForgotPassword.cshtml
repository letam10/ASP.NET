@model TechShop.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container py-5" style="margin-top:70px;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-card border-0 shadow-lg p-4" style="border-radius: 20px;">
                <h3 class="text-primary mb-3"><i class="bi bi-shield-lock-fill me-2"></i>Quên mật khẩu</h3>
                <p class="text-secondary mb-4 small">Nhập email của bạn để nhận liên kết đặt lại mật khẩu.</p>

                <form asp-action="ForgotPassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label class="form-label">Địa chỉ Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 border-secondary-subtle">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>
                            <input asp-for="Email" class="form-control border-start-0 border-secondary-subtle ps-0" 
                                   placeholder="you@example.com" required />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button class="btn btn-primary w-100 py-2">
                        <i class="bi bi-send-fill me-2"></i>Gửi link đặt lại mật khẩu
                    </button>
                    
                    <div class="mt-4 text-center">
                        <a asp-action="Login" class="text-muted small text-decoration-none hover-link">
                            <i class="bi bi-arrow-left me-1"></i>Quay lại đăng nhập
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
