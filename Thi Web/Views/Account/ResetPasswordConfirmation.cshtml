@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công";
}
<div class="container py-5" style="margin-top:70px;">
    <div class="row justify-content-center text-center">
        <div class="col-md-6">
            <div class="card bg-card border-0 shadow-lg p-5" style="border-radius: 20px;">
                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                </div>
                <h3 class="text-primary mb-3">Thành công!</h3>
                <p class="text-secondary mb-4">
                    Mật khẩu của bạn đã được cập nhật thành công. Bây giờ bạn có thể sử dụng mật khẩu mới để truy cập TechShop.
                </p>
                <a class="btn btn-primary px-5 py-2" asp-action="Login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
                </a>
            </div>
        </div>
    </div>
</div>
