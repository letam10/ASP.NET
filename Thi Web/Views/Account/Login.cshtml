@model TechShop.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập — TechShop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: #060910;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        /* ---- Animated background ---- */
        .bg-layer {
            position: fixed;
            inset: 0;
            z-index: 0;
            background:
                radial-gradient(ellipse 70% 60% at 20% 20%, rgba(99,102,241,0.18) 0%, transparent 60%),
                radial-gradient(ellipse 50% 50% at 80% 80%, rgba(6,182,212,0.12) 0%, transparent 55%),
                radial-gradient(ellipse 60% 40% at 60% 10%, rgba(168,85,247,0.1) 0%, transparent 50%),
                #060910;
        }

        .bg-grid {
            position: fixed;
            inset: 0;
            z-index: 0;
            background-image:
                linear-gradient(rgba(99,102,241,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(99,102,241,0.04) 1px, transparent 1px);
            background-size: 48px 48px;
        }

        .orb {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            z-index: 0;
            animation: orbFloat 8s ease-in-out infinite;
        }

        .orb-1 {
            width: 400px; height: 400px;
            background: rgba(99,102,241,0.12);
            top: -100px; left: -100px;
            animation-delay: 0s;
        }

        .orb-2 {
            width: 300px; height: 300px;
            background: rgba(6,182,212,0.1);
            bottom: -80px; right: -80px;
            animation-delay: 3s;
        }

        .orb-3 {
            width: 200px; height: 200px;
            background: rgba(168,85,247,0.08);
            top: 40%; left: 60%;
            animation-delay: 5s;
        }

        @@keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -20px) scale(1.05); }
            66% { transform: translate(-20px, 15px) scale(0.97); }
        }

        /* ---- Wrapper ---- */
        .login-wrapper {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 440px;
            padding: 20px;
        }

        /* ---- Brand bar ---- */
        .brand-bar {
            text-align: center;
            margin-bottom: 28px;
        }

        .brand-bar a {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: #f1f5f9;
            font-family: 'Syne', sans-serif;
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.02em;
        }

        .brand-icon-wrap {
            width: 38px; height: 38px;
            border-radius: 10px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            box-shadow: 0 4px 16px rgba(99,102,241,0.4);
        }

        /* ---- Card ---- */
        .login-card {
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 24px;
            padding: 36px 36px 32px;
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow:
                0 0 0 1px rgba(99,102,241,0.1),
                0 24px 60px rgba(0,0,0,0.5),
                inset 0 1px 0 rgba(255,255,255,0.06);
        }

        .card-heading {
    margin-bottom: 28px;
    text-align: center;
}

.card-heading h1 {
    font-family: 'Syne', sans-serif;
    font-size: 1.55rem;
    font-weight: 800;
    color: #f1f5f9;
    letter-spacing: -0.03em;
    margin-bottom: 6px;
}

.card-heading p {
    font-size: 0.88rem;
    color: #64748b;
}

        /* ---- Social buttons ---- */
        .social-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 24px;
        }

        .btn-social {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 11px 14px;
            border-radius: 12px;
            font-size: 0.84rem;
            font-weight: 600;
            text-decoration: none;
            border: 1px solid rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.04);
            color: #cbd5e1;
            transition: all 0.22s cubic-bezier(0.4,0,0.2,1);
            position: relative;
            overflow: hidden;
            white-space: nowrap;
        }

        .btn-social::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0);
            transition: background 0.22s ease;
        }

        .btn-social:hover {
            color: #f1f5f9;
            transform: translateY(-2px);
        }

        .btn-social:hover::after {
            background: rgba(255,255,255,0.05);
        }

        .btn-social:active { transform: translateY(0); }

        .btn-google:hover {
            border-color: rgba(234,67,53,0.4);
            box-shadow: 0 6px 20px rgba(234,67,53,0.12);
        }

        .btn-facebook:hover {
            border-color: rgba(24,119,242,0.4);
            box-shadow: 0 6px 20px rgba(24,119,242,0.15);
        }

        .google-icon { width: 16px; height: 16px; flex-shrink: 0; }
        .btn-facebook i { font-size: 1rem; color: #3b82f6; }

        /* ---- Divider ---- */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 24px;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(255,255,255,0.07);
        }

        .divider span {
            font-size: 0.75rem;
            font-weight: 600;
            color: #475569;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            flex-shrink: 0;
        }

        /* ---- Form fields ---- */
        .field-group { margin-bottom: 18px; }

        .field-label {
            display: block;
            font-size: 0.78rem;
            font-weight: 600;
            color: #64748b;
            letter-spacing: 0.07em;
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.88rem;
            color: #475569;
            pointer-events: none;
            z-index: 1;
        }

        .field-input {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            color: #f1f5f9;
            font-size: 0.9rem;
            font-family: 'Inter', sans-serif;
            padding: 11px 14px 11px 40px;
            outline: none;
            transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
            -webkit-appearance: none;
        }

        .field-input::placeholder { color: #2d3d50; }

        .field-input:focus {
            border-color: rgba(99,102,241,0.6);
            background: rgba(99,102,241,0.06);
            box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
        }

        .field-error {
            display: block;
            margin-top: 5px;
            font-size: 0.77rem;
            color: #f87171;
        }

        /* Alert */
        .alert-form {
            background: rgba(239,68,68,0.1);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 10px;
            color: #fca5a5;
            font-size: 0.83rem;
            padding: 10px 14px;
            margin-bottom: 18px;
        }

        /* Remember row */
        .remember-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 22px;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            color: #64748b;
            cursor: pointer;
            user-select: none;
        }

        .remember-label input[type="checkbox"] {
            width: 16px; height: 16px;
            border-radius: 4px;
            accent-color: #6366f1;
            cursor: pointer;
        }

        /* ---- Submit button ---- */
        .btn-login {
            width: 100%;
            padding: 13px 20px;
            border-radius: 13px;
            border: none;
            background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-size: 0.92rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            cursor: pointer;
            transition: all 0.22s cubic-bezier(0.4,0,0.2,1);
            box-shadow: 0 4px 20px rgba(99,102,241,0.35);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 22px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(99,102,241,0.5);
            background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        }

        .btn-login:active { transform: translateY(0); }

        /* ---- Footer ---- */
        .card-footer-text {
            text-align: center;
            font-size: 0.85rem;
            color: #475569;
        }

        .card-footer-text a {
            color: #818cf8;
            font-weight: 600;
            text-decoration: none;
            transition: color 0.2s;
        }

        .card-footer-text a:hover { color: #a5b4fc; }

        /* ---- Bottom link ---- */
        .bottom-link {
            text-align: center;
            margin-top: 20px;
            font-size: 0.82rem;
            color: #334155;
        }

        .bottom-link a {
            color: #475569;
            text-decoration: none;
            transition: color 0.2s;
        }

        .bottom-link a:hover { color: #94a3b8; }

        /* ---- Responsive ---- */
        @@media (max-width: 480px) {
            .login-card { padding: 28px 22px 26px; border-radius: 20px; }
            .social-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="bg-layer"></div>
    <div class="bg-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="login-wrapper">

        <!-- Brand -->
        <div class="brand-bar">
            <a href="/">
                <div class="brand-icon-wrap">
                    <i class="bi bi-cpu-fill" style="color:#fff"></i>
                </div>
                TechShop
            </a>
        </div>

        <!-- Card -->
        <div class="login-card">
            <div class="card-heading">
                <h1>Chào mừng trở lại 👋</h1>
                <p>Đăng nhập để tiếp tục mua sắm</p>
            </div>

            <!-- Social login -->
            <div class="social-grid">
                <a asp-controller="Account" asp-action="ExternalLogin"
                   asp-route-provider="Google"
                   asp-route-returnUrl="@ViewBag.ReturnUrl"
                   class="btn-social btn-google">
                    <svg class="google-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Google
                </a>
                <a asp-controller="Account" asp-action="ExternalLogin"
                   asp-route-provider="Facebook"
                   asp-route-returnUrl="@ViewBag.ReturnUrl"
                   class="btn-social btn-facebook">
                    <i class="bi bi-facebook"></i>
                    Facebook
                </a>
            </div>

            <!-- Divider -->
            <div class="divider"><span>hoặc dùng email</span></div>

            <!-- Form -->
            <form asp-action="Login" method="post" asp-route-returnUrl="@ViewBag.ReturnUrl">
                @Html.AntiForgeryToken()

                @if (TempData["Error"] != null)
                {
                    <div class="alert-form">@TempData["Error"]</div>
                }
                <div asp-validation-summary="ModelOnly" class="alert-form"></div>

                <div class="field-group">
                    <label asp-for="Email" class="field-label"></label>
                    <div class="field-wrap">
                        <i class="bi bi-envelope field-icon"></i>
                        <input asp-for="Email" class="field-input"
                               placeholder="email@example.com"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Password" class="field-label"></label>
                    <div class="field-wrap">
                        <i class="bi bi-lock field-icon"></i>
                        <input asp-for="Password" class="field-input"
                               placeholder="••••••••"
                               autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="remember-row">
                    <label class="remember-label">
                        <input asp-for="RememberMe" type="checkbox" />
                        Ghi nhớ đăng nhập
                    </label>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Đăng nhập
                </button>
                <a asp-controller="Account" asp-action="ForgotPassword">Quên mật khẩu?</a>

                <p class="card-footer-text">
                    Chưa có tài khoản?
                    <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
                </p>
            </form>
        </div>

        <div class="bottom-link">
            <a href="/"><i class="bi bi-arrow-left me-1"></i>Về trang chủ</a>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>