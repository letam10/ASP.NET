@model TechShop.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="container py-5" style="margin-top:70px;">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-card border-0 shadow-lg p-4" style="border-radius: 20px;">
                <h3 class="text-primary mb-3"><i class="bi bi-key-fill me-2"></i>Đặt lại mật khẩu</h3>
                <p class="text-secondary mb-4 small">Tạo mật khẩu mới cho tài khoản của bạn.</p>

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <input asp-for="Email" type="hidden" />
                    <input asp-for="Token" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Xác nhận mật khẩu</label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" required />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button class="btn btn-primary w-100 py-2">
                        <i class="bi bi-check-circle-fill me-2"></i>Xác nhận và lưu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
