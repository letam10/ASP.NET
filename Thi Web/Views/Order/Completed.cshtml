@model TechShop.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";

    // Cấu hình QR Code Thanh Toán
    string bankId = "MB"; // Thay bằng ngân hàng của bạn
    string accountNo = "0123456789";
    string accountName = "TECHSHOP VN";
    string amount = Model!.TotalAmount.ToString("0");
    string content = $"Thanh toan don hang {Model.Id}";
    string qrUrl = $"https://img.vietqr.io/image/{bankId}-{accountNo}-compact.png?amount={amount}&addInfo={content}&accountName={accountName}";
}

<div class="order-success-page">
    <div class="container py-5" style="margin-top:70px">
        <div class="success-wrap text-center">
            <div class="success-icon">
                <i class="bi bi-bag-check-fill text-success" style="font-size: 4rem;"></i>
            </div>
            <h2 class="mt-4">Đặt hàng thành công!</h2>
            <p class="text-muted lead">Cảm ơn bạn đã mua hàng tại TechShop. Vui lòng thanh toán để hoàn tất đơn hàng.</p>

            <div class="card bg-light border-0 shadow-sm mx-auto mt-4" style="max-width: 500px;">
                <div class="card-body">
                    <h5 class="text-danger fw-bold fs-3 mb-3">@Model.TotalAmount.ToString("N0") ₫</h5>
                    <img src="@qrUrl" alt="QR Thanh toán" class="img-fluid rounded mb-3" style="max-width: 250px; border: 2px solid #dee2e6;" />
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-clock-history me-1"></i> Đơn hàng tự động hủy sau:
                        <strong id="countdown" class="fs-5 text-danger">10:00</strong>
                    </div>
                </div>
            </div>

            <div class="order-info-card mt-4 mx-auto" style="max-width: 800px; background: #fff; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05);">
                <div class="row text-start">
                    <div class="col-md-6">
                        <p><strong>Mã đơn hàng:</strong> #@Model.Id.ToString("D6")</p>
                        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        <p><strong>Trạng thái:</strong> <span class="badge bg-warning text-dark">@Model.Status</span></p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Người nhận:</strong> @Model.FullName</p>
                        <p><strong>Địa chỉ:</strong> @Model.Address, @Model.City</p>
                        <p><strong>Tổng tiền:</strong> <span class="text-primary fw-bold">@Model.TotalAmount.ToString("N0") ₫</span></p>
                    </div>
                </div>
                <hr>
                <h6 class="mb-3 text-start">Chi tiết sản phẩm</h6>
                @foreach (var od in Model.OrderDetails)
                {
                    <div class="d-flex justify-content-between align-items-center mb-2 text-start">
                        <span>@od.Product?.Name <small class="text-muted">x@od.Quantity</small></span>
                        <span>@((od.UnitPrice * od.Quantity).ToString("N0")) ₫</span>
                    </div>
                }
                <hr>
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Tổng cộng</span>
                    <span class="text-gradient">@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="bi bi-house me-2"></i>Về trang chủ
                </a>
                <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-clock-history me-2"></i>Xem đơn hàng
                </a>
            </div>
        </div>
    </div>
</div>
<script>
    var countDownDate = new Date("@Model.OrderDate.ToString("yyyy-MM-ddTHH:mm:ss")");
    countDownDate.setMinutes(countDownDate.getMinutes() + 10);

    var x = setInterval(function() {
        var now = new Date().getTime();
        var distance = countDownDate.getTime() - now;

        var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        var seconds = Math.floor((distance % (1000 * 60)) / 1000);

        document.getElementById("countdown").innerHTML =
            (minutes < 10 ? "0" + minutes : minutes) + ":" + (seconds < 10 ? "0" + seconds : seconds);

        if (distance < 0) {
            clearInterval(x);
            document.getElementById("countdown").innerHTML = "ĐÃ HẾT HẠN";
            alert("Đơn hàng đã quá hạn thanh toán và bị hệ thống hủy tự động!");
            window.location.href = '/Order/MyOrders';
        }
    }, 1000);
</script>