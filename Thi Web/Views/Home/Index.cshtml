<!-- Minigame Section -->
<section class="minigame-section py-5" data-aos="zoom-in-up">
    <div class="container">
        <div class="minigame-card p-5 text-center">
            <div class="row align-items-center">
                <div class="col-lg-7 text-lg-start mb-4 mb-lg-0">
