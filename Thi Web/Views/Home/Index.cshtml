@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<TechShop.Models.Category>;
    var promoProducts = ViewBag.PromoProducts as List<TechShop.Models.Product>;

    // === Hướng dẫn: Dán link YouTube (Watch URL) vào biến này để đổi Video Background ===
    string heroYoutubeUrl = "https://www.youtube.com/watch?v=Hgg7M3kSqyE";

    // --- Logic Tự Động Xử Lý Link YouTube (Video ID Extraction) ---
    string heroVideoId = "qr_WWOQD-S4"; // Mặc định
    try {
        if (!string.IsNullOrEmpty(heroYoutubeUrl)) {
            if (heroYoutubeUrl.Contains("v=")) {
                heroVideoId = heroYoutubeUrl.Split("v=")[1].Split("&")[0];
            } else if (heroYoutubeUrl.Contains("be/")) {
                heroVideoId = heroYoutubeUrl.Split("be/")[1].Split("?")[0];
            } else if (heroYoutubeUrl.Contains("embed/")) {
                heroVideoId = heroYoutubeUrl.Split("embed/")[1].Split("?")[0];
            }
        }
    } catch { /* Fallback to default ID if error */ }

    string heroEmbedUrl = $"https://www.youtube.com/embed/{heroVideoId}?controls=0&showinfo=0&rel=0&autoplay=1&loop=1&mute=1&playlist={heroVideoId}&enablejsapi=1&origin={Context.Request.Scheme}://{Context.Request.Host}";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        /* === SWIPER PREMIUM STYLES === */
        #promoCarousel {
            padding: 20px 0 50px;
        }

        .swiper-slide {
            height: auto;
            display: flex;
            justify-content: center;
        }

        .swiper-pagination-bullet-active {
            background: var(--primary-light) !important;
        }

        [data-theme="dark"] .swiper-pagination-bullet {
            background: rgba(255, 255, 255, 0.4);
        }

        .swiper-button-next, .swiper-button-prev {
            color: var(--primary-light);
            background: rgba(255,255,255,0.1);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .swiper-button-next:after, .swiper-button-prev:after {
            font-size: 1.2rem;
            font-weight: bold;
        }

        /* Promo Section Header */
        .promo-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .promo-title {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0;
        }

        .promo-badge-count {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 600;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }

        /* Discount Badge */
        .discount-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background: linear-gradient(45deg, #ff0055, #ffcc00);
            color: white;
            padding: 4px 10px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 0.8rem;
            z-index: 5;
            box-shadow: 0 4px 10px rgba(255, 0, 85, 0.4);
            text-transform: uppercase;
        }

        .old-price {
            text-decoration: line-through;
            color: rgba(255,255,255,0.4);
            font-size: 0.85rem;
            margin-right: 8px;
        }
        [data-theme="light"] .old-price {
            color: #999;
        }

        /* Premium empty state */
        .wishlist-empty {
            background: rgba(255, 255, 255, 0.03);
            border: 1px dashed var(--border);
            border-radius: 20px;
            padding: 40px;
            text-align: center;
        }

        .btn-cyber-outline {
            background: transparent;
            border: 2px solid #ff00ff;
            color: #ff00ff !important;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            box-shadow: 0 0 10px rgba(255, 0, 255, 0.3);
            position: relative;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .btn-cyber-outline:hover {
            background: #ff00ff;
            color: white !important;
            box-shadow: 0 0 20px #ff00ff, 0 0 40px rgba(255, 0, 255, 0.5);
            transform: scale(1.05);
        }

        /* AJAX Loading overlay */
        #product-list-container {
            position: relative;
            min-height: 200px;
            transition: opacity 0.3s ease;
        }
        #product-list-container.loading {
            opacity: 0.5;
            pointer-events: none;
        }

        /* === PREMIUM HERO SECTION UPGRADE === */
        .hero-section.premium {
            position: relative;
            min-height: 85vh; 
            overflow: hidden;
            display: flex;
            align-items: center;
            background: #000;
        }

        .video-background-container {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 0;
            overflow: hidden;
        }

        .video-foreground,
        .video-foreground iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        /* Scale up iframe to hide YouTube UI and black bars */
        @@media (min-aspect-ratio: 16/9) {
          .video-foreground { height: 300%; top: -100%; }
        }
        @@media (max-aspect-ratio: 16/9) {
          .video-foreground { width: 300%; left: -100%; }
        }

        .video-foreground iframe {
            opacity: 0.6; /* Làm mờ video để chữ dễ đọc */
        }

        .hero-overlay-gradient {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(135deg, rgba(15, 23, 42, 0.9) 0%, rgba(15, 23, 42, 0.4) 50%, rgba(88, 28, 135, 0.3) 100%);
            z-index: 1;
        }

        .hero-badge-glass {
            display: inline-block;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 600;
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--primary-light);
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            animation: fadeInDown 0.8s ease backwards;
        }

        .hero-title-premium {
            font-size: 4rem;
            font-weight: 900;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -1px;
            text-shadow: 0 10px 30px rgba(0,0,0,0.5);
            animation: fadeInLeft 1s ease 0.2s backwards;
        }

        .hero-sub-premium {
            font-size: 1.15rem;
            color: rgba(255,255,255,0.8);
            max-width: 550px;
            line-height: 1.6;
            animation: fadeInLeft 1s ease 0.4s backwards;
        }

        .glass-btn {
            background: rgba(255,255,255,0.05) !important;
            backdrop-filter: blur(5px);
            border-color: rgba(255,255,255,0.2) !important;
        }
        .glass-btn:hover {
            background: rgba(255,255,255,0.15) !important;
            border-color: #fff !important;
        }

        .shadow-primary { box-shadow: 0 8px 25px rgba(var(--bs-primary-rgb), 0.4); }

        .hero-stats-glass {
            display: flex;
            gap: 40px;
            animation: fadeInUp 1s ease 0.6s backwards;
        }
        .stat-item-glass { display: flex; flex-direction: column; border-right: 1px solid rgba(255,255,255,0.1); padding-right: 40px; }
        .stat-item-glass .n { font-size: 1.5rem; font-weight: 800; color: #fff; }
        .stat-item-glass .l { font-size: 0.8rem; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px; }

        /* Scene animations on right */
        .hero-image-scene { position: relative; display: flex; justify-content: center; align-items: center; }
        .scene-glow { 
            position: absolute; width: 400px; height: 400px; 
            background: radial-gradient(circle, rgba(var(--primary-rgb), 0.2) 0%, transparent 70%); 
            filter: blur(30px); animation: pulseGlow 4s infinite alternate;
        }
        .main-device-img {
            max-width: 100%; border-radius: 30px; 
            box-shadow: 0 30px 60px rgba(0,0,0,0.4);
            transform: perspective(1000px) rotateY(-10deg);
            transition: all 0.5s ease;
            animation: mainImageEntry 1.2s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
        }
        .main-device-img:hover { transform: perspective(1000px) rotateY(0deg) scale(1.02); }

        .float-card-glass {
            position: absolute;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            padding: 12px 20px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #fff;
            font-weight: 600;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            z-index: 3;
        }
        .float-card-glass i { font-size: 1.5rem; color: var(--primary-light); }
        .fc-tech { top: -20px; right: 0; animation: floatY 3s ease-in-out infinite; }
        .fc-speed { bottom: 20px; left: -40px; animation: floatY 4s ease-in-out infinite reverse; }

        /* Keyframes */
        @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }
        @@keyframes fadeInLeft { from { opacity: 0; transform: translateX(-30px); } to { opacity: 1; transform: translateX(0); } }
        @@keyframes fadeInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @@keyframes pulseGlow { from { opacity: 0.5; transform: scale(0.9); } to { opacity: 1; transform: scale(1.1); } }
        @@keyframes floatY { 0% { transform: translateY(0); } 50% { transform: translateY(-15px); } 100% { transform: translateY(0); } }
        @@keyframes mainImageEntry { from { opacity: 0; transform: perspective(1000px) rotateY(-30deg) scale(0.8); } to { opacity: 1; transform: perspective(1000px) rotateY(-10deg) scale(1); } }

        /* --- Mobile Adjustments --- */
        @@media (max-width: 991px) {
            .hero-title-premium { font-size: 2.8rem; }
            .hero-section.premium { text-align: center; }
            .hero-sub-premium { margin: 0 auto; }
            .hero-actions { justify-content: center; }
            .hero-stats-glass { justify-content: center; gap: 20px; }
            .stat-item-glass { padding-right: 20px; }
        }

        /* --- LIGHT THEME SYNC --- */
        [data-theme="light"] .hero-section.premium {
            background: #f8fbff;
        }
        [data-theme="light"] .video-foreground iframe {
            opacity: 1; /* Hiển thị hoàn toàn độ rõ của video */
            filter: none;
        }
        [data-theme="light"] .hero-overlay-gradient {
            /* Chỉ giữ một lớp phủ cực mỏng để bảo vệ độ đọc của chữ */
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.5) 0%, rgba(255, 255, 255, 0.2) 50%, rgba(37, 99, 235, 0.05) 100%);
        }
        [data-theme="light"] .hero-title-premium {
            color: #000; /* Đen đậm hơn để tương phản tốt trên nền video rõ */
            text-shadow: 0 1px 10px rgba(255,255,255,0.8);
        }
        [data-theme="light"] .hero-sub-premium {
            color: #222;
        }
        [data-theme="light"] .stat-item-glass .n { color: #111; }
        [data-theme="light"] .stat-item-glass .l { color: #666; }
        [data-theme="light"] .float-card-glass {
            background: rgba(255, 255, 255, 0.8);
            color: #111;
            border-color: rgba(0, 0, 0, 0.1);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }
        [data-theme="light"] .hero-badge-glass {
            background: rgba(37, 99, 235, 0.1);
            color: #2563eb;
            border-color: rgba(37, 99, 235, 0.2);
        }
        [data-theme="light"] .glass-btn {
            background: rgba(0, 0, 0, 0.05) !important;
            color: #111 !important;
            border-color: rgba(0, 0, 0, 0.2) !important;
        }
        [data-theme="light"] .glass-btn:hover {
            background: rgba(0, 0, 0, 0.1) !important;
            border-color: #111 !important;
        }
    </style>
}

<!-- Hero Section Upgrade -->
<section class="hero-section premium" data-aos="fade">
    <div class="video-background-container">
        <!-- Sử dụng IFrame cho YouTube video đã được tự động xử lý link nhúng -->
        <div class="video-foreground">
            <iframe src="@heroEmbedUrl" 
                    frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>
        </div>
        <div class="hero-overlay-gradient"></div>
    </div>
    <div class="container position-relative" style="z-index: 2;">
        <div class="row align-items-center min-vh-80">
            <div class="col-lg-6 hero-text-animate">
                <div class="hero-badge-glass mb-3">🔥 Siêu hội công nghệ — Giảm 40%</div>
                <h1 class="hero-title-premium">
                    Trải nghiệm <br>
                    <span class="text-gradient">Đẳng cấp</span><br>
                    Công nghệ mới
                </h1>
                <p class="hero-sub-premium mb-4">
                    Sở hữu những thiết bị đỉnh cao nhất từ laptop gaming đến linh kiện PC chuyên nghiệp. Bảo hành 1 đổi 1, giao hàng thần tốc.
                </p>
                <div class="hero-actions d-flex gap-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4 shadow-primary">
                        <i class="bi bi-rocket-takeoff me-2"></i>Sở hữu ngay
                    </a>
                    <a href="#categories-section" class="btn btn-outline-light btn-lg rounded-pill px-4 glass-btn">
                        Ưu đãi đặc biệt
                    </a>
                </div>
                <div class="hero-stats-glass mt-5">
                    <div class="stat-item-glass"><span class="n">500+</span><span class="l">Sản phẩm</span></div>
                    <div class="stat-item-glass"><span class="n">10K+</span><span class="l">Thành viên</span></div>
                    <div class="stat-item-glass border-0"><span class="n">4.9★</span><span class="l">Uy tín</span></div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-image-scene">
                    <div class="scene-glow"></div>
                    <img src="https://images.unsplash.com/photo-1593642702821-c8da6771f0c6?w=600" alt="Tech" class="main-device-img" />
                    <!-- Animated elements -->
                    <div class="float-card-glass fc-tech">
                        <i class="bi bi-shield-check"></i>
                        <span>Bảo hành 24T</span>
                    </div>
                    <div class="float-card-glass fc-speed">
                        <i class="bi bi-lightning-charge"></i>
                        <span>Giao hàng 2h</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section class="py-5 bg-dark-2" id="categories-section" data-aos="fade-up">
    <div class="container">
        <h2 class="section-title">Danh mục <span class="text-gradient">sản phẩm</span></h2>
        <div class="row g-3 justify-content-center">
            @foreach (var cat in categories!)
            {
                var icons = new Dictionary<string, string> { { "Laptop", "bi-laptop" }, { "Chuột", "bi-mouse" }, { "Bàn phím", "bi-keyboard" }, { "Màn hình", "bi-display" }, { "Linh kiện PC", "bi-cpu" } };
                var icon = icons.ContainsKey(cat.Name) ? icons[cat.Name] : "bi-box";
                <div class="col-6 col-md-4 col-lg-2">
                    <a href="javascript:void(0)" onclick="filterByCategory(@cat.Id, this)"
                           class="cat-card @(ViewBag.SelectedCategory == cat.Id ? "active" : "")">
                        <i class="bi @icon"></i>
                        <span>@cat.Name</span>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<!-- Products Grid & Wishlist Carousel -->
<section class="py-5" data-aos="fade-up">
    <div class="container">
        
        <!-- Product List filtered by Category -->
        <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
            <h2 class="section-title mb-0" id="current-category-title">
                @if (ViewBag.SelectedCategory != null)
                {
                    <span>@categories?.FirstOrDefault(c => c.Id == (int)ViewBag.SelectedCategory)?.Name</span>
                }
                else if (!string.IsNullOrEmpty(ViewBag.Search as string))
                {
                    <span>Kết quả: "@ViewBag.Search"</span>
                }
                else
                {
                    <span>Sản phẩm <span class="text-gradient">nổi bật</span></span>
                }
            </h2>
            <span class="text-muted" id="product-count">@Model.Count sản phẩm</span>
        </div>

        <div id="product-list-container">
            @await Html.PartialAsync("_ProductList", Model)
        </div>

        <!-- Promo Carousel Section -->
        <div class="promo-header mt-5 pt-4">
            <h2 class="promo-title">Sản phẩm <span class="text-gradient">đang giảm giá</span></h2>
            @if (promoProducts != null && promoProducts.Any())
            {
                <span class="promo-badge-count">@promoProducts.Count ưu đãi</span>
            }
        </div>

        @if (promoProducts == null || !promoProducts.Any())
        {
            <div class="wishlist-empty mt-3">
                <i class="bi bi-tag display-6 text-muted mb-2 d-block"></i>
                <h6>Hiện chưa có sản phẩm khuyến mãi</h6>
                <p class="small text-muted">Quay lại sau để nhận những ưu đãi hấp dẫn nhé!</p>
            </div>
        }
        else
        {
            <div class="swiper mt-3" id="promoCarousel">
                <div class="swiper-wrapper">
                    @foreach (var product in promoProducts)
                    {
                        decimal discountPercent = 0;
                        if (product.DiscountPrice.HasValue && product.Price > 0)
                        {
                            discountPercent = Math.Round((1 - (product.DiscountPrice.Value / product.Price)) * 100);
                        }

                        <div class="swiper-slide h-auto">
                            <div class="product-card h-100" style="width: 100%;">
                                <div class="product-img-wrap">
                                    @if (discountPercent > 0)
                                    {
                                        <div class="discount-badge">-@discountPercent%</div>
                                    }
                                    <img src="@(product.ImageUrl ?? "https://via.placeholder.com/300x200")" alt="@product.Name" class="product-img" />
                                    <div class="product-overlay">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id" class="btn btn-light btn-sm">
                                            <i class="bi bi-eye me-1"></i>Chi tiết
                                        </a>
                                    </div>
                                </div>
                                <div class="product-body">
                                    <p class="product-cat">@product.Category?.Name</p>
                                    <h6 class="product-name" style="height: 2.4em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                                        @product.Name
                                    </h6>
                                    <div class="product-footer d-flex flex-column align-items-start">
                                        @if (product.DiscountPrice.HasValue)
                                        {
                                            <div>
                                                <span class="old-price">@product.Price.ToString("N0") ₫</span>
                                                <span class="product-price text-danger">@product.DiscountPrice.Value.ToString("N0") ₫</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="product-price">@product.Price.ToString("N0") ₫</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <!-- Controls -->
                <div class="swiper-pagination"></div>
                <!-- Add Navigation -->
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
            </div>
        }
    </div>
</section>

