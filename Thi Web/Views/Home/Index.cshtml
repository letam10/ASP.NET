@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let productSwiper = null;
        let wishlistSwiper = null;

        function initProductSwiper() {
            if ($('#productCarousel').length) {
                if (productSwiper !== null) productSwiper.destroy(true, true);
                productSwiper = new Swiper('#productCarousel', {
                    slidesPerView: 1, spaceBetween: 25,
                    loop: true,
                    autoplay: { delay: 3000, disableOnInteraction: false },
                    pagination: { el: '.swiper-pagination', clickable: true },
                    navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
                    breakpoints: { 576: { slidesPerView: 2 }, 992: { slidesPerView: 3 }, 1200: { slidesPerView: 4 } }
                });
            }
        }

        function initPromoSwiper() {
            if ($('#promoCarousel').length) {
                if (wishlistSwiper !== null) wishlistSwiper.destroy(true, true);
                wishlistSwiper = new Swiper('#promoCarousel', {
                    slidesPerView: 1, spaceBetween: 20,
                    loop: true,
                    autoplay: { delay: 4000, disableOnInteraction: false },
                    pagination: { el: '.swiper-pagination', clickable: true },
                    navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
                    breakpoints: { 576: { slidesPerView: 2 }, 992: { slidesPerView: 3 }, 1200: { slidesPerView: 4 } }
                });
            }
        }

        $(document).ready(function () {
            initProductSwiper();
            initPromoSwiper();

            // Newsletter form handling inside $(document).ready
            $('#newsletterForm').on('submit', function(e) {
                e.preventDefault();
                const form = $(this);
                const btn = form.find('button[type="submit"]');
                const email = form.find('input[name="email"]').val();
                
                // Toast setup
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 4500,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                btn.prop('disabled', true);
                btn.find('.btn-text').addClass('d-none');
                btn.find('.spinner-border').removeClass('d-none');
                
                $.ajax({
                    url: '/Home/SubscribeNewsletter',
                    type: 'POST',
                    data: { email: email },
                    success: function(res) {
                        if(res.success) {
                            Toast.fire({
                                icon: 'success',
                                title: res.message || 'Đăng ký thành công!',
                                background: '#10b981', // Vibrant Green
                                color: '#fff',
                                iconColor: '#fff'
                            });
                            form[0].reset();
                        } else {
                            Toast.fire({
                                icon: 'error',
                                title: res.message || 'Có lỗi xảy ra',
                                background: '#ef4444', // Vibrant Red
                                color: '#fff',
                                iconColor: '#fff'
                            });
                        }
                    },
                    error: function() {
                        Toast.fire({
                            icon: 'error',
                            title: 'Không thể kết nối đến máy chủ.',
                            background: '#ef4444',
                            color: '#fff'
                        });
                    },
                    complete: function() {
                        btn.prop('disabled', false);
                        btn.find('.btn-text').removeClass('d-none');
                        btn.find('.spinner-border').addClass('d-none');
                    }
                });
            });
        });

        function filterByCategory(catId, btn) {
            $('.cat-card').removeClass('active');
            $(btn).addClass('active');
            const container = $('#product-list-container');
            container.addClass('loading');
            $.ajax({
                url: '/Home/FilterProducts',
                data: { categoryId: catId },
                success: function (html) {
                    container.html(html);
                    initProductSwiper();
                    const title = catId ? $(btn).find('span').text() : 'Sản phẩm <span class="text-gradient">nổi bật</span>';
                    $('#current-category-title').html(title);
                    const count = $(html).find('.swiper-slide').length;
                    $('#product-count').text(count + ' sản phẩm');
                },
                complete: function() { container.removeClass('loading'); }
            });
        }

    </script>
}
