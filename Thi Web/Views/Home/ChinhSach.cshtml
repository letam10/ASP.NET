@{
    ViewData["Title"] = "Chính sách";
}

<div class="container py-5" style="margin-top:70px">
    <h2 class="page-title mb-4"><i class="bi bi-file-earmark-text me-2"></i>Chính sách</h2>
    <div class="card p-4" style="background:var(--bg-card);border:1px solid var(--border);">
        <h5>Chính sách đổi trả</h5>
        <p class="text-muted mb-4">Khách hàng có thể đổi trả trong 30 ngày với sản phẩm đủ điều kiện theo quy định của TechShop.</p>

        <h5>Bảo hành</h5>
        <p class="text-muted mb-4">Sản phẩm được bảo hành chính hãng theo thời hạn ghi trên hóa đơn và thông tin sản phẩm.</p>

        <h5>Vận chuyển</h5>
        <p class="text-muted mb-0">TechShop hỗ trợ giao hàng toàn quốc, thời gian giao tùy khu vực và trạng thái tồn kho.</p>
    </div>
</div>
