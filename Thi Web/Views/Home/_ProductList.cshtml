@model List<TechShop.Models.Product>

<div class="swiper" id="productCarousel">
    <div class="swiper-wrapper">
        @foreach (var product in Model)
        {
            <div class="swiper-slide">
                <div class="product-card" style="width: 100%;">
                    <button type="button"
                            class="wishlist-btn"
                            onclick="toggleWishlist(@product.Id, this)"
                            title="Yêu thích">
                        <i class="bi bi-heart"></i>
                    </button>
                    <div class="product-img-wrap">
                        <img src="@(product.ImageUrl ?? "https://via.placeholder.com/300x200")" alt="@product.Name" class="product-img" />
                        <div class="product-overlay">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id" class="btn btn-light btn-sm">
                                <i class="bi bi-eye me-1"></i>Chi tiết
                            </a>
                        </div>
                        @if (product.Stock < 5 && product.Stock > 0)
                        {
                            <span class="badge-stock">Sắp hết</span>
                        }
                    </div>
                    <div class="product-body">
                        <p class="product-cat">@product.Category?.Name</p>
                        <h6 class="product-name" style="height: 2.4em; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                            @product.Name
                        </h6>
                        <div class="product-footer">
                            <span class="product-price">@product.Price.ToString("N0") ₫</span>
                            <form asp-controller="Product" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button type="submit" class="btn-add-cart" title="Thêm vào giỏ">
                                    <i class="bi bi-cart-plus"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <!-- Add Pagination -->
    <div class="swiper-pagination"></div>
    <!-- Add Navigation -->
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
</div>
