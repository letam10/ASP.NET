@model TechShop.Models.ApplicationUser
@{
    ViewData["Title"] = "Vòng Quay May Mắn";
}

<style>
    .wheel-wrapper {
        position: relative;
        width: 350px;
        height: 350px;
        margin: 2rem auto;
    }

    .wheel-pointer {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 0;
        height: 0;
        border-left: 20px solid transparent;
        border-right: 20px solid transparent;
        border-top: 40px solid #dc3545; /* Mũi tên đỏ */
        z-index: 10;
        filter: drop-shadow(0px 4px 2px rgba(0,0,0,0.3));
    }

    .wheel {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 8px solid #343a40;
        box-shadow: 0 0 20px rgba(0,0,0,0.2);
        overflow: hidden;
        transition: transform 4s cubic-bezier(0.17, 0.67, 0.12, 0.99); /* Hiệu ứng quay mượt */
        /* Tạo 6 ô màu bằng conic-gradient */
        background: conic-gradient( #f8f9fa 0 60deg, #ffc107 60deg 120deg, #0dcaf0 120deg 180deg, #198754 180deg 240deg, #f8f9fa 240deg 300deg, #0d6efd 300deg 360deg );
        position: relative;
    }

    .wheel-text {
        position: absolute;
        width: 50%;
        height: 20px;
        top: calc(50% - 10px);
        transform-origin: 100% 50%;
        text-align: left;
        padding-left: 20px;
        font-weight: bold;
        font-size: 14px;
        color: #333;
    }

    /* Đặt chữ vào đúng 6 ô */
    .txt-1 {
        transform: rotate(5deg);
    }

    .txt-2 {
        transform: rotate(65deg);
    }

    .txt-3 {
        transform: rotate(125deg);
    }

    .txt-4 {
        transform: rotate(185deg);
        color: #fff;
    }

    .txt-5 {
        transform: rotate(245deg);
    }

    .txt-6 {
        transform: rotate(305deg);
        color: #fff;
    }

    .btn-spin {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background: #dc3545;
        color: white;
        font-weight: bold;
        border: 4px solid #fff;
        cursor: pointer;
        z-index: 5;
        box-shadow: 0 0 10px rgba(0,0,0,0.3);
    }

        .btn-spin:active {
            transform: translate(-50%, -50%) scale(0.95);
        }

        .btn-spin:disabled {
            background: #6c757d;
            cursor: not-allowed;
        }
</style>

<div class="container py-5 text-center" style="margin-top:70px">
    <h2 class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i>Vòng Quay May Mắn</h2>
    <p class="fs-5">Điểm của bạn: <strong id="currentPoints" class="text-primary fs-3">@Model.LoyaltyPoints</strong> điểm</p>
    <p class="text-muted">(Mỗi lượt quay tốn 50 điểm)</p>

    <div class="wheel-wrapper">
        <div class="wheel-pointer"></div>
        <div class="wheel" id="wheel">
            <div class="wheel-text txt-1">Trượt rồi</div>
            <div class="wheel-text txt-2">Voucher 500k</div>
            <div class="wheel-text txt-3">Chúc may mắn</div>
            <div class="wheel-text txt-4">100 Điểm</div>
            <div class="wheel-text txt-5">Trượt rồi</div>
            <div class="wheel-text txt-6">Voucher 50k</div>
        </div>
        <button class="btn-spin" id="spinBtn" onclick="spinWheel()">QUAY</button>
    </div>
</div>

<div class="modal fade" id="prizeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="modal-body">
                <i class="bi bi-gift text-danger mb-3" style="font-size: 4rem;"></i>
                <h3 class="text-primary mb-3">Kết quả quay!</h3>
                <h4 id="prizeText" class="fw-bold"></h4>
            </div>
            <div class="mt-3">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const wheelLabels = [
            "Trượt rồi",
            "Voucher 500k",
            "Chúc may mắn lần sau",
            "Voucher 100K",
            "Trượt rồi",
            "Voucher 50K"
        ];

        let currentRotation = 0;
        let isSpinning = false;

        function spinWheel() {
            if (isSpinning) return;

            const spinBtn = document.getElementById('spinBtn');
            const wheel = document.getElementById('wheel');

            if (!spinBtn || !wheel) return;

            isSpinning = true;
            spinBtn.disabled = true;

            $.post('/Game/SpinWheel', function (res) {
                if (!res.success) {
                    alert(res.message);
                    isSpinning = false;
                    spinBtn.disabled = false;
                    return;
                }
                const totalSegments = wheelLabels.length;
                const segmentAngle = 360 / totalSegments;

                // Mũi tên đang ở phía trên.
                // Muốn ô trúng nằm đúng dưới mũi tên thì quay tới tâm ô đó.
                const targetAngle = 360 - (res.winningIndex * segmentAngle) - (segmentAngle / 2);

                const extraSpins = 360 * 6;
                currentRotation += extraSpins + targetAngle;

                wheel.style.transition = 'transform 4.5s cubic-bezier(0.2, 0.8, 0.2, 1)';
                wheel.style.transform = `rotate(${currentRotation}deg)`;

                setTimeout(function () {
                    document.getElementById('prizeText').textContent = res.winningLabel;
                    document.getElementById('currentPoints').textContent = res.currentPoints;

                    const modalEl = document.getElementById('prizeModal');
                    const modal = new bootstrap.Modal(modalEl);
                    modal.show();

                    isSpinning = false;
                    spinBtn.disabled = false;
                }, 4700);
            }).fail(function () {
                alert('Không thể quay lúc này.');
                isSpinning = false;
                spinBtn.disabled = false;
            });
        }
    </script>
}