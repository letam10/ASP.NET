@model TechShop.Controllers.ProfileViewModel
@inject UserManager<TechShop.Models.ApplicationUser> UserManager
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var currentUser = await UserManager.GetUserAsync(User);
    var is2FAEnabled = currentUser != null && await UserManager.GetTwoFactorEnabledAsync(currentUser);
}

<style>
    .profile-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%);
        border-bottom: 1px solid rgba(99,102,241,.2);
        padding: 36px 0 28px;
        margin-top: 70px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
    }
    .profile-header::before {
        content: '';
        position: absolute; inset: 0;
        background:
            radial-gradient(ellipse 60% 80% at 10% 50%, rgba(99,102,241,.12) 0%, transparent 70%),
            radial-gradient(ellipse 40% 60% at 90% 30%, rgba(168,85,247,.09) 0%, transparent 70%);
        pointer-events: none;
    }
    .profile-header .container { position: relative; }
    .profile-header-label {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .72rem; font-weight: 700; letter-spacing: .12em;
        text-transform: uppercase; color: #818cf8;
        background: rgba(99,102,241,.12);
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 100px; padding: 4px 12px; margin-bottom: 16px;
    }
    .profile-avatar-row { display: flex; align-items: center; gap: 20px; }
    .profile-avatar {
        width: 68px; height: 68px; border-radius: 18px;
        background: rgba(99,102,241,.15);
        border: 2px solid rgba(99,102,241,.4);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; font-weight: 800;
        color: #a5b4fc; flex-shrink: 0;
        box-shadow: 0 0 0 4px rgba(99,102,241,.08);
    }
    .profile-meta h4 {
        color: #f1f5f9; font-weight: 800;
        font-size: 1.4rem; margin: 0 0 4px; letter-spacing: -.02em;
    }
    .profile-meta-info {
        display: flex; flex-wrap: wrap; gap: 12px;
        font-size: .84rem; color: #64748b;
    }
    .profile-meta-info span { display: flex; align-items: center; gap: 6px; }
    .profile-meta-info i { color: #6366f1; }
    .profile-layout {
        max-width: 860px; margin: 0 auto;
        padding-bottom: 60px;
        display: flex; flex-direction: column; gap: 20px;
    }
    .profile-alert {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 18px; border-radius: 14px;
        font-size: .88rem; font-weight: 500;
    }
    .profile-alert.success {
        background: rgba(16,185,129,.1);
        border: 1px solid rgba(16,185,129,.25); color: #6ee7b7;
    }
    .profile-alert.danger {
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.25); color: #fca5a5;
    }
    .profile-alert i { font-size: 1rem; flex-shrink: 0; }
    .profile-alert .btn-close { margin-left: auto; filter: invert(1); opacity: .5; transition: opacity .2s; }
    .profile-alert .btn-close:hover { opacity: 1; }
    .profile-cards {
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    @@media (max-width: 700px) { .profile-cards { grid-template-columns: 1fr; } }
    .pf-card {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 20px; overflow: hidden;
        transition: border-color .25s;
    }
    .pf-card:hover { border-color: rgba(99,102,241,.25); }
    .pf-card-head {
        display: flex; align-items: center; gap: 10px;
        padding: 18px 22px 16px;
        border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .pf-card-icon {
        width: 36px; height: 36px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; flex-shrink: 0;
    }
    .pf-card-icon.blue {
        background: rgba(99,102,241,.15); color: #818cf8;
        border: 1px solid rgba(99,102,241,.2);
    }
    .pf-card-icon.amber {
        background: rgba(245,158,11,.12); color: #fbbf24;
        border: 1px solid rgba(245,158,11,.2);
    }
    .pf-card-icon.green {
        background: rgba(16,185,129,.12); color: #34d399;
        border: 1px solid rgba(16,185,129,.2);
    }
    .pf-card-head h6 {
        margin: 0; font-size: .9rem; font-weight: 700;
        color: #e2e8f0; letter-spacing: -.01em;
    }
    .pf-card-body { padding: 22px; }
    .pf-field { margin-bottom: 18px; }
    .pf-field:last-child { margin-bottom: 0; }
    .pf-label {
        display: block; margin-bottom: 7px;
        font-size: .78rem; font-weight: 600;
        letter-spacing: .06em; text-transform: uppercase; color: #64748b;
    }
    .pf-input {
        width: 100%;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.09);
        border-radius: 11px; color: #f1f5f9;
        font-size: .88rem; padding: 10px 14px;
        outline: none;
        transition: border-color .2s, background .2s, box-shadow .2s;
        -webkit-appearance: none;
    }
    .pf-input::placeholder { color: #334155; }
    .pf-input:focus {
        border-color: #6366f1;
        background: rgba(99,102,241,.06);
        box-shadow: 0 0 0 3px rgba(99,102,241,.12);
    }
    .pf-input[readonly] { opacity: .5; cursor: not-allowed; }
    .pf-input[readonly]:focus {
        border-color: rgba(255,255,255,.09);
        background: rgba(255,255,255,.04);
        box-shadow: none;
    }
    .pf-hint { display: block; margin-top: 5px; font-size: .75rem; color: #475569; }
    .pf-error { display: block; margin-top: 5px; font-size: .78rem; color: #f87171; }
    .pf-input-wrap { position: relative; }
    .pf-input-wrap .pf-input { padding-left: 40px; }
    .pf-input-icon {
        position: absolute; left: 13px; top: 50%;
        transform: translateY(-50%);
        font-size: .85rem; color: #475569; pointer-events: none;
    }
    .btn-pf {
        display: flex; align-items: center; justify-content: center;
        gap: 8px; width: 100%;
        padding: 11px 20px; border-radius: 12px;
        font-size: .88rem; font-weight: 700;
        border: none; cursor: pointer;
        transition: transform .15s, box-shadow .2s, background .2s;
        margin-top: 22px; letter-spacing: .01em;
    }
    .btn-pf:hover { transform: translateY(-1px); }
    .btn-pf:active { transform: translateY(0); }
    .btn-pf.primary {
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
        color: #fff; box-shadow: 0 4px 16px rgba(99,102,241,.3);
    }
    .btn-pf.primary:hover { box-shadow: 0 6px 22px rgba(99,102,241,.45); }
    .btn-pf.amber {
        background: linear-gradient(135deg, #d97706 0%, #f59e0b 100%);
        color: #fff; box-shadow: 0 4px 16px rgba(245,158,11,.25);
    }
    .btn-pf.amber:hover { box-shadow: 0 6px 22px rgba(245,158,11,.4); }

    /* 2FA Card */
    .twofa-card {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 20px; overflow: hidden;
        transition: border-color .25s;
    }
    .twofa-card:hover { border-color: rgba(16,185,129,.25); }
    .twofa-card-body {
        padding: 22px 24px;
        display: flex; justify-content: space-between;
        align-items: center; flex-wrap: wrap; gap: 20px;
    }
    .twofa-status {
        display: flex; align-items: center; gap: 10px;
        padding: 5px 14px; border-radius: 100px;
        font-size: .8rem; font-weight: 700;
        letter-spacing: .05em;
    }
    .twofa-status.on {
        background: rgba(16,185,129,.12);
        border: 1px solid rgba(16,185,129,.3);
        color: #34d399;
    }
    .twofa-status.off {
        background: rgba(100,116,139,.12);
        border: 1px solid rgba(100,116,139,.25);
        color: #94a3b8;
    }
    .btn-2fa {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 10px 20px; border-radius: 12px;
        font-size: .88rem; font-weight: 700;
        border: none; cursor: pointer;
        transition: transform .15s, box-shadow .2s;
        text-decoration: none;
    }
    .btn-2fa:hover { transform: translateY(-1px); }
    .btn-2fa.enable {
        background: linear-gradient(135deg, #059669, #10b981);
        color: #fff; box-shadow: 0 4px 14px rgba(16,185,129,.3);
    }
    .btn-2fa.enable:hover { box-shadow: 0 6px 20px rgba(16,185,129,.45); color: #fff; }
    .btn-2fa.disable {
        background: rgba(239,68,68,.12);
        border: 1px solid rgba(239,68,68,.25);
        color: #f87171;
    }
    .btn-2fa.disable:hover {
        background: rgba(239,68,68,.2);
        color: #f87171;
    }
</style>

<!-- ===== PAGE HEADER ===== -->
<div class="profile-header">
    <div class="container">
        <div class="profile-header-label">
            <i class="bi bi-person-circle"></i> Tài khoản của tôi
        </div>
        <div class="profile-avatar-row">
            <div class="profile-avatar">
                @(Model.FullName?.Substring(0, 1).ToUpper() ?? "U")
            </div>
            <div class="profile-meta">
                <h4>@Model.FullName</h4>
                <div class="profile-meta-info">
                    <span><i class="bi bi-envelope"></i> @Model.Email</span>
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <span><i class="bi bi-telephone"></i> @Model.PhoneNumber</span>
                    }
                    <span>
                        <i class="bi bi-shield-@(is2FAEnabled ? "check" : "x")"></i>
                        2FA: @(is2FAEnabled ? "Đang bật" : "Chưa bật")
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ===== MAIN CONTENT ===== -->
<div class="container">
    <div class="profile-layout">

        <!-- Alerts -->
        @if (TempData["Success"] != null)
        {
            <div class="profile-alert success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["Success"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="profile-alert danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span>@TempData["Error"]</span>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- 2 cột: thông tin + mật khẩu -->
        <div class="profile-cards">

            <!-- Thông tin cá nhân -->
            <div class="pf-card">
                <div class="pf-card-head">
                    <div class="pf-card-icon blue"><i class="bi bi-person"></i></div>
                    <h6>Thông tin cá nhân</h6>
                </div>
                <div class="pf-card-body">
                    <form asp-controller="Profile" asp-action="Index" method="post">
                        @Html.AntiForgeryToken()
                        <div class="pf-field">
                            <label asp-for="FullName" class="pf-label"></label>
                            <input asp-for="FullName" class="pf-input" placeholder="Nguyễn Văn A" />
                            <span asp-validation-for="FullName" class="pf-error"></span>
                        </div>
                        <div class="pf-field">
                            <label asp-for="Email" class="pf-label"></label>
                            <input asp-for="Email" class="pf-input" readonly />
                            <span class="pf-hint"><i class="bi bi-info-circle me-1"></i>Email không thể thay đổi</span>
                        </div>
                        <div class="pf-field">
                            <label asp-for="PhoneNumber" class="pf-label"></label>
                            <input asp-for="PhoneNumber" class="pf-input" placeholder="0901 234 567" />
                        </div>
                        <button type="submit" class="btn-pf primary">
                            <i class="bi bi-save"></i> Lưu thông tin
                        </button>
                    </form>
                </div>
            </div>

            <!-- Đổi mật khẩu -->
            <div class="pf-card">
                <div class="pf-card-head">
                    <div class="pf-card-icon amber"><i class="bi bi-shield-lock"></i></div>
                    <h6>Đổi mật khẩu</h6>
                </div>
                <div class="pf-card-body">
                    <form asp-controller="Profile" asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="pf-field">
                            <label class="pf-label">Mật khẩu hiện tại</label>
                            <div class="pf-input-wrap">
                                <i class="bi bi-lock pf-input-icon"></i>
                                <input type="password" name="CurrentPassword" class="pf-input" placeholder="••••••••" />
                            </div>
                        </div>
                        <div class="pf-field">
                            <label class="pf-label">Mật khẩu mới</label>
                            <div class="pf-input-wrap">
                                <i class="bi bi-lock-fill pf-input-icon"></i>
                                <input type="password" name="NewPassword" class="pf-input" placeholder="Tối thiểu 6 ký tự" />
                            </div>
                        </div>
                        <div class="pf-field">
                            <label class="pf-label">Xác nhận mật khẩu mới</label>
                            <div class="pf-input-wrap">
                                <i class="bi bi-shield-check pf-input-icon"></i>
                                <input type="password" name="ConfirmPassword" class="pf-input" placeholder="Nhập lại mật khẩu mới" />
                            </div>
                        </div>
                        <button type="submit" class="btn-pf amber">
                            <i class="bi bi-key"></i> Đổi mật khẩu
                        </button>
                    </form>
                </div>
            </div>

        </div>

        <!-- 2FA — full width, nằm ngoài profile-cards -->
        <div class="twofa-card">
            <div class="pf-card-head">
                <div class="pf-card-icon green"><i class="bi bi-shield-check"></i></div>
                <h6>Xác minh 2 bước (2FA)</h6>
                <div class="twofa-status @(is2FAEnabled ? "on" : "off") ms-auto">
                    <i class="bi bi-circle-fill" style="font-size:.5rem"></i>
                    @(is2FAEnabled ? "Đang bật" : "Chưa bật")
                </div>
            </div>
            <div class="twofa-card-body">
                <div>
                    @if (is2FAEnabled)
                    {
                        <p style="color:#94a3b8;font-size:.88rem;margin:0">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            Tài khoản đang được bảo vệ bởi xác minh 2 bước.
                            Mỗi lần đăng nhập sẽ yêu cầu mã từ <strong style="color:#e2e8f0">Google Authenticator</strong>.
                        </p>
                    }
                    else
                    {
                        <p style="color:#94a3b8;font-size:.88rem;margin:0">
                            <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                            Chưa bật xác minh 2 bước. Hãy bật để bảo vệ tài khoản tốt hơn bằng
                            <strong style="color:#e2e8f0">Google Authenticator</strong>.
                        </p>
                    }
                </div>
                <div>
                    @if (is2FAEnabled)
                    {
                        <form asp-controller="Account" asp-action="DisableTwoFactor" method="post"
                              onsubmit="return confirm('Bạn có chắc muốn tắt xác minh 2 bước?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-2fa disable">
                                <i class="bi bi-shield-x"></i> Tắt 2FA
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="TwoFactorSetup" class="btn-2fa enable">
                            <i class="bi bi-shield-check"></i> Bật 2FA ngay
                        </a>
                    }
                </div>
            </div>
        </div>

    </div>
</div>