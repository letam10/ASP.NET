@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "So sánh sản phẩm";
    var allSpecs = Model.SelectMany(p => p.Specifications.Select(s => s.SpecName)).Distinct().ToList();
}

<style>
    /* === WRAPPER === */
    .cmp-wrapper { margin-top: 80px; padding-bottom: 80px; }

    /* === HEADER === */
    .cmp-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%);
        border-bottom: 1px solid rgba(99,102,241,.2);
        padding: 32px 0 24px;
        margin-bottom: 36px;
        position: relative; overflow: hidden;
    }

    .cmp-header::before {
        content: ''; position: absolute; inset: 0;
        background:
            radial-gradient(ellipse 60% 80% at 10% 50%, rgba(99,102,241,.11) 0%, transparent 70%),
            radial-gradient(ellipse 40% 60% at 90% 30%, rgba(168,85,247,.08) 0%, transparent 70%);
        pointer-events: none;
    }

    .cmp-header .container { position: relative; }

    .cmp-header-label {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .72rem; font-weight: 700; letter-spacing: .12em;
        text-transform: uppercase; color: #818cf8;
        background: rgba(99,102,241,.12);
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 100px; padding: 4px 12px; margin-bottom: 10px;
    }

    .cmp-header h1 {
        font-size: clamp(1.4rem, 2.5vw, 2rem);
        font-weight: 800; color: #f1f5f9; margin: 0 0 4px;
        letter-spacing: -.02em;
    }

    .cmp-header h1 .accent {
        background: linear-gradient(135deg, #818cf8 0%, #c084fc 100%);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .cmp-header p { color: #64748b; font-size: .88rem; margin: 0; }

    /* === EMPTY STATE === */
    .cmp-empty {
        max-width: 480px; margin: 0 auto;
        text-align: center; padding: 60px 20px;
    }

    .cmp-empty-icon {
        width: 64px; height: 64px; border-radius: 18px;
        background: rgba(99,102,241,.1);
        border: 1px solid rgba(99,102,241,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem; color: #6366f1;
        margin: 0 auto 20px;
    }

    .cmp-empty h4 { color: #e2e8f0; font-weight: 700; margin-bottom: 8px; }
    .cmp-empty p  { color: #475569; font-size: .9rem; margin-bottom: 6px; }

    .cmp-empty-hint {
        background: rgba(99,102,241,.08);
        border: 1px solid rgba(99,102,241,.18);
        border-radius: 12px; padding: 12px 16px;
        font-size: .84rem; color: #818cf8; margin-bottom: 20px;
    }

    .btn-cmp-go {
        display: inline-flex; align-items: center; gap: 8px;
        background: linear-gradient(135deg, #6366f1 0%, #818cf8 100%);
        color: #fff; border: none; border-radius: 100px;
        padding: 11px 28px; font-size: .88rem; font-weight: 700;
        text-decoration: none; cursor: pointer;
        box-shadow: 0 6px 20px rgba(99,102,241,.3);
        transition: transform .18s, box-shadow .2s;
    }

    .btn-cmp-go:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(99,102,241,.45); color: #fff; }

    /* === TABLE WRAPPER === */
    .cmp-table-wrap { overflow-x: auto; }

    /* === COMPARE TABLE === */
    .cmp-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .875rem;
        min-width: 560px;
    }

    /* Header row (product cards) */
    .cmp-table thead tr {
        background: #0f172a;
        border-bottom: 2px solid rgba(99,102,241,.2);
    }

    .cmp-table thead th {
        padding: 0;
        vertical-align: top;
        border: none;
    }

    .cmp-table thead th:first-child {
        width: 200px; min-width: 160px;
        padding: 20px 18px;
        font-size: .72rem; font-weight: 700;
        letter-spacing: .1em; text-transform: uppercase;
        color: #475569; vertical-align: middle;
    }

    /* Product card inside th */
    .cmp-prod-card {
        padding: 20px 16px;
        display: flex; flex-direction: column;
        align-items: center; gap: 10px;
        text-align: center;
        border-left: 1px solid rgba(255,255,255,.05);
    }

    .cmp-prod-img-wrap {
        width: 110px; height: 110px;
        background: #1e293b;
        border-radius: 14px; overflow: hidden;
        display: flex; align-items: center; justify-content: center;
        padding: 10px; flex-shrink: 0;
    }

    .cmp-prod-img-wrap img {
        width: 100%; height: 100%; object-fit: contain;
    }

    .cmp-prod-name {
        font-size: .88rem; font-weight: 700; color: #e2e8f0;
        line-height: 1.35;
        display: -webkit-box; -webkit-line-clamp: 2;
        -webkit-box-orient: vertical; overflow: hidden;
    }

    .cmp-prod-price {
        font-size: 1rem; font-weight: 800; color: #f1f5f9;
        letter-spacing: -.01em;
    }

    .cmp-prod-actions { display: flex; gap: 8px; }

    .btn-cmp-detail {
        display: inline-flex; align-items: center; gap: 5px;
        background: rgba(99,102,241,.15);
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 8px; padding: 6px 12px;
        font-size: .75rem; font-weight: 600; color: #a5b4fc;
        text-decoration: none;
        transition: background .18s, color .18s;
    }

    .btn-cmp-detail:hover { background: #6366f1; color: #fff; }

    .btn-cmp-remove {
        display: inline-flex; align-items: center; justify-content: center;
        width: 30px; height: 30px;
        background: rgba(239,68,68,.1);
        border: 1px solid rgba(239,68,68,.2);
        border-radius: 8px; color: #f87171;
        cursor: pointer; font-size: .8rem;
        transition: background .18s;
    }

    .btn-cmp-remove:hover { background: rgba(239,68,68,.25); }

    /* Body rows */
    .cmp-table tbody tr {
        border-bottom: 1px solid rgba(255,255,255,.04);
        transition: background .15s;
    }

    .cmp-table tbody tr:last-child { border-bottom: none; }
    .cmp-table tbody tr:hover { background: rgba(255,255,255,.02); }

    .cmp-table tbody tr:nth-child(even) { background: rgba(255,255,255,.015); }
    .cmp-table tbody tr:nth-child(even):hover { background: rgba(255,255,255,.03); }

    .cmp-table tbody td {
        padding: 13px 18px;
        vertical-align: middle;
        border: none;
        color: #94a3b8;
        text-align: center;
    }

    /* Spec label cell */
    .cmp-spec-label {
        text-align: left !important;
        font-size: .75rem; font-weight: 700;
        letter-spacing: .06em; text-transform: uppercase;
        color: #475569 !important;
        border-right: 1px solid rgba(255,255,255,.05) !important;
        white-space: nowrap;
    }

    /* Spec value */
    .cmp-spec-val { color: #cbd5e1 !important; font-size: .87rem; }

    /* Dash for missing */
    .cmp-spec-dash { color: #334155 !important; }

    /* Section divider row */
    .cmp-section-row td {
        background: rgba(99,102,241,.06) !important;
        color: #6366f1 !important;
        font-size: .7rem !important; font-weight: 700 !important;
        letter-spacing: .12em !important; text-transform: uppercase !important;
        text-align: left !important;
        padding: 8px 18px !important;
        border-top: 1px solid rgba(99,102,241,.15) !important;
    }

    /* Product column borders */
    .cmp-table tbody td:not(:first-child) {
        border-left: 1px solid rgba(255,255,255,.04);
    }
</style>

<!-- HEADER -->
<div class="cmp-header">
    <div class="container">
        <div class="cmp-header-label">
            <i class="bi bi-bar-chart-line"></i> So sánh sản phẩm
        </div>
        <h1>So sánh <span class="accent">thông số kỹ thuật</span></h1>
        <p>Đang so sánh @Model.Count / 2 sản phẩm</p>
    </div>
</div>

<div class="cmp-wrapper">
    <div class="container">

        @if (Model.Count < 2)
        {
            <div class="cmp-empty">
                <div class="cmp-empty-icon"><i class="bi bi-bar-chart"></i></div>
                <h4>Chưa đủ sản phẩm để so sánh</h4>
                <p>Cần chọn đủ <strong style="color:#e2e8f0">2 sản phẩm</strong> cùng danh mục để bắt đầu so sánh.</p>

                @if (Model.Any())
                {
                    <div class="cmp-empty-hint">
                        <i class="bi bi-check-circle me-1"></i>
                        Đã chọn: <strong>@Model[0].Name</strong> — hãy thêm 1 sản phẩm nữa
                    </div>
                }

                <a asp-controller="Product" asp-action="Index" class="btn-cmp-go">
                    <i class="bi bi-grid"></i> Chọn sản phẩm để so sánh
                </a>
            </div>
        }
        else
        {
            <div class="cmp-table-wrap">
                <table class="cmp-table">
                    <thead>
                        <tr>
                            <th>Thông số</th>
                            @foreach (var p in Model)
                            {
                                <th>
                                    <div class="cmp-prod-card">
                                        <div class="cmp-prod-img-wrap">
                                            <img src="@(p.ImageUrl ?? "https://via.placeholder.com/150")"
                                                 alt="@p.Name" />
                                        </div>
                                        <p class="cmp-prod-name">@p.Name</p>
                                        <p class="cmp-prod-price">@p.Price.ToString("N0") ₫</p>
                                        <div class="cmp-prod-actions">
                                            <a asp-action="Detail" asp-route-id="@p.Id" class="btn-cmp-detail">
                                                <i class="bi bi-eye"></i> Chi tiết
                                            </a>
                                            <form asp-action="RemoveFromCompare" method="post" class="m-0">
                                                <input type="hidden" name="productId" value="@p.Id" />
                                                <button type="submit" class="btn-cmp-remove" title="Xóa khỏi so sánh">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Section: Tổng quan -->
                        <tr class="cmp-section-row">
                            <td colspan="@(Model.Count + 1)">
                                <i class="bi bi-info-circle me-2"></i>Tổng quan
                            </td>
                        </tr>
                        <tr>
                            <td class="cmp-spec-label">Bảo hành</td>
                            @foreach (var p in Model)
                            {
                                <td class="cmp-spec-val">@(string.IsNullOrEmpty(p.WarrantyPolicy) ? "-" : p.WarrantyPolicy)</td>
                            }
                        </tr>

                        <!-- Section: Thông số kỹ thuật -->
                        @if (allSpecs.Any())
                        {
                            <tr class="cmp-section-row">
                                <td colspan="@(Model.Count + 1)">
                                    <i class="bi bi-cpu me-2"></i>Thông số kỹ thuật
                                </td>
                            </tr>
                            @foreach (var specName in allSpecs)
                            {
                                <tr>
                                    <td class="cmp-spec-label">@specName</td>
                                    @foreach (var p in Model)
                                    {
                                        var val = p.Specifications.FirstOrDefault(s => s.SpecName == specName)?.SpecValue;
                                        if (string.IsNullOrEmpty(val))
                                        {
                                            <td class="cmp-spec-dash">—</td>
                                        }
                                        else
                                        {
                                            <td class="cmp-spec-val">@val</td>
                                        }
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>
