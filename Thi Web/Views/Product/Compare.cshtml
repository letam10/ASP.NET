@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "So sánh Thông số | TechShop";
    var allSpecs = Model.SelectMany(p => p.Specifications.Select(s => s.SpecName)).Distinct().ToList();
    int maxLimit = 4;
    int currentCount = Model.Count;
}

<style>
    /* === HEADER (From Booking) === */
    .cmp-header {
        background: var(--bg-dark);
        border-bottom: 1px solid var(--border);
        padding: 36px 0 28px;
        margin-top: 70px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }

    .cmp-header::before {
        content: '';
        position: absolute; inset: 0;
        background:
            radial-gradient(ellipse 60% 80% at 10% 50%, rgba(99,102,241,.12) 0%, transparent 70%),
            radial-gradient(ellipse 40% 60% at 90% 30%, rgba(168,85,247,.09) 0%, transparent 70%);
        pointer-events: none;
    }

    .cmp-header .container { position: relative; text-align: center; }

    .cmp-header-label {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: .72rem; font-weight: 700; letter-spacing: .12em;
        text-transform: uppercase; color: #818cf8;
        background: rgba(99,102,241,.12);
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 100px; padding: 4px 14px; margin-bottom: 14px;
    }

    .cmp-header h1 {
        font-size: clamp(1.5rem, 3vw, 2.2rem);
        font-weight: 800; color: var(--text-primary);
        margin: 0 0 8px; letter-spacing: -.02em;
    }

    .cmp-header h1 .accent {
        background: linear-gradient(135deg, #818cf8 0%, #c084fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .cmp-header p { color: var(--text-secondary); font-size: .92rem; margin: 0; }

    /* === FEATURES (From Booking) === */
    .cmp-features {
        display: flex; justify-content: center;
        flex-wrap: wrap; gap: 10px;
        margin-bottom: 36px;
    }

    .cmp-f-badge {
        display: inline-flex; align-items: center; gap: 7px;
        padding: 7px 14px; border-radius: 100px;
        font-size: .78rem; font-weight: 600;
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--text-secondary);
    }

    .cmp-f-badge i { color: #6366f1; }

    /* === MAIN CARD (From Booking) === */
    .cmp-card {
        max-width: 1200px;
        margin: 0 auto 60px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    }

    .cmp-card-head {
        padding: 26px 32px;
        border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 14px;
        background: rgba(99,102,241,.05);
    }

    .cmp-card-head-icon {
        width: 44px; height: 44px; border-radius: 13px;
        background: rgba(99,102,241,.15);
        border: 1px solid rgba(99,102,241,.25);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; color: #818cf8; flex-shrink: 0;
    }

    .cmp-card-head h5 {
        margin: 0 0 3px; font-size: 1rem; font-weight: 800;
        color: var(--text-primary); letter-spacing: -.01em;
    }

    .cmp-card-head p { margin: 0; font-size: .8rem; color: var(--text-secondary); }

    /* === SEARCH SECTION === */
    .cmp-search-inner {
        padding: 24px 32px;
        background: rgba(255,255,255,0.01);
        border-bottom: 1px solid var(--border);
    }

    #cmpProductSearch {
        background: var(--input-bg);
        border: 1px solid var(--border);
        color: var(--text-primary);
        border-radius: 12px;
        padding: 12px 18px 12px 45px;
        font-size: .95rem;
        transition: all 0.3s ease;
    }
    
    #cmpProductSearch:focus {
        border-color: #6366f1;
        background: rgba(99,102,241,.06);
        box-shadow: 0 0 0 3px rgba(99,102,241,.12);
    }
    
    .search-icon-btn {
        position: absolute;
        left: 45px; top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        color: #818cf8;
        opacity: 0.8;
    }

    .search-results-dropdown {
        position: absolute;
        top: calc(100% + 10px);
        left: 32px; right: 32px;
        background: var(--bg-card);
        backdrop-filter: blur(20px);
        border: 1px solid var(--border);
        border-radius: 16px;
        max-height: 400px;
        overflow-y: auto;
        display: none;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        z-index: 1001;
    }

    .search-result-item {
        display: flex; align-items: center; gap: 15px;
        padding: 12px 20px;
        cursor: pointer;
        transition: all 0.2s;
        border-bottom: 1px solid var(--border);
    }
    .search-result-item:hover { background: rgba(99,102,241, 0.08); }
    .search-result-item img { width: 45px; height: 45px; object-fit: contain; background: #fff; border-radius: 8px; padding: 4px; }
    .search-result-info h6 { margin: 0; font-size: .9rem; font-weight: 700; color: var(--text-primary); }
    .search-result-info span { font-size: 0.8rem; color: #818cf8; font-weight: 600; }

    /* === COMPARISON TABLE === */
    .table-responsive { width: 100%; overflow-x: auto; }
    .cmp-table { width: 100%; border-collapse: separate; border-spacing: 0; table-layout: fixed; min-width: 800px; }
    
    .cmp-table th, .cmp-table td { padding: 20px; border-bottom: 1px solid var(--border); }

    .col-label { 
        width: 200px; 
        background: rgba(99,102,241, 0.02) !important; 
        font-weight: 700; 
        color: #64748b; 
        text-transform: uppercase; 
        font-size: 0.72rem; 
        letter-spacing: 0.1em;
        border-right: 1px solid var(--border);
    }

    .col-product { position: relative; vertical-align: top; border-right: 1px solid var(--border); }
    .col-product:last-child { border-right: none; }
    
    .cmp-prod-card { text-align: center; }
    .cmp-prod-img { width: 100px; height: 100px; object-fit: contain; margin-bottom: 12px; background: white; border-radius: 12px; padding: 10px; }
    .cmp-prod-name { font-weight: 800; font-size: 0.88rem; color: var(--text-primary); margin-bottom: 6px; height: 2.6em; overflow: hidden; line-height: 1.3; }
    .cmp-prod-price { font-weight: 800; color: #818cf8; font-size: 1rem; }
    
    .btn-remove-cmp {
        position: absolute; top: 10px; right: 10px;
        width: 28px; height: 28px; border-radius: 8px;
        background: rgba(244, 63, 94, 0.1); color: #f43f5e;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem; cursor: pointer; transition: all 0.2s;
    }
    .btn-remove-cmp:hover { background: #f43f5e; color: white; }

    /* EMPTY SLOT (Like Booking divider) */
    .digital-slot {
        height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: center;
        border: 2px dashed var(--border); border-radius: 16px; 
        cursor: pointer; transition: all 0.3s; color: #64748b;
        background: rgba(0,0,0,0.01);
    }
    .digital-slot:hover { border-color: #818cf8; background: rgba(99,102,241, 0.05); color: #818cf8; }
    .digital-slot i { font-size: 2rem; margin-bottom: 10px; opacity: 0.5; }
    .digital-slot span { font-weight: 700; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; }

    /* Spec Rows */
    .spec-divider {
        background: rgba(99,102,241, 0.05); height: 40px; 
        display: flex; align-items: center; justify-content: center;
        text-transform: uppercase; font-size: 0.7rem; font-weight: 800; letter-spacing: 2px; color: #6366f1;
    }

    .spec-value { font-size: 0.85rem; font-weight: 600; text-align: center; color: var(--text-primary); }
    .highlight-diff { background: rgba(99,102,241, 0.04); }
    
    /* Footer Action */
    .cmp-footer-action { padding: 30px; border-top: 1px solid var(--border); text-align: center; }
    .btn-wipe {
        display: inline-flex; align-items: center; gap: 8px;
        background: transparent; border: 1.5px solid var(--border);
        padding: 10px 30px; border-radius: 100px;
        font-size: .88rem; font-weight: 700; color: var(--text-secondary);
        transition: all 0.2s;
    }
    .btn-wipe:hover { border-color: #f43f5e; color: #f43f5e; background: rgba(244,63,94,0.05); }
</style>

<!-- PAGE HEADER (From Booking) -->
<div class="cmp-header">
    <div class="container">
        <div class="cmp-header-label">
            <i class="bi bi-intersect"></i> Hệ thống so sánh
        </div>
        <h1>So sánh <span class="accent">Thông số & Hiệu năng</span></h1>
        <p>Phân tích chuyên sâu — Đối chiếu kỹ thuật — Lựa chọn tối ưu</p>
    </div>
</div>

<!-- FEATURES (From Booking) -->
<div class="container">
    <div class="cmp-features">
        <span class="cmp-f-badge"><i class="bi bi-cpu"></i> Phân tích phần cứng</span>
        <span class="cmp-f-badge"><i class="bi bi-graph-up-arrow"></i> Điểm số hiệu năng</span>
        <span class="cmp-f-badge"><i class="bi bi-display"></i> Trải nghiệm thị giác</span>
        <span class="cmp-f-badge"><i class="bi bi-battery-charging"></i> Thời lượng pin thực tế</span>
    </div>
</div>

<!-- MAIN CARD (From Booking) -->
<div class="container">
    <div class="cmp-card">
        
        <div class="cmp-card-head">
            <div class="cmp-card-head-icon">
                <i class="bi bi-layout-three-columns"></i>
            </div>
            <div>
                <h5>Đối chiếu sản phẩm</h5>
                <p>Thêm tối đa 4 sản phẩm cùng danh mục để thực hiện phân tích</p>
            </div>
        </div>

        <!-- Search Selection -->
        <div class="cmp-search-inner position-relative">
            <i class="bi bi-search search-icon-btn"></i>
            <input type="text" id="cmpProductSearch" class="form-control" placeholder="Tìm tên sản phẩm để bắt đầu so sánh..." autocomplete="off">
            <div id="searchSuggestions" class="search-results-dropdown"></div>
        </div>

        <!-- Comparison Table -->
        <div class="table-responsive">
            <table class="cmp-table">
                <thead>
                    <tr>
                        <th class="col-label">Thông số cốt lõi</th>
                        @for (int i = 0; i < maxLimit; i++)
                        {
                            <th class="col-product text-center">
                                @if (i < currentCount)
                                {
                                    var p = Model[i];
                                    <div class="cmp-prod-card">
                                        <div class="btn-remove-cmp" onclick="removeFromCompare(@p.Id)" title="Xóa">
                                            <i class="bi bi-x-lg"></i>
                                        </div>
                                        <a href="@Url.Action("Detail", "Product", new { id = p.Id })">
                                            <img src="@(p.ImageUrl ?? "https://via.placeholder.com/150")" class="cmp-prod-img" alt="@p.Name">
                                        </a>
                                        <div class="cmp-prod-name">@p.Name</div>
                                        <div class="cmp-prod-price">@p.Price.ToString("N0") ₫</div>
                                    </div>
                                }
                                else
                                {
                                    <div class="digital-slot" onclick="focusSearch()">
                                        <i class="bi bi-plus-circle"></i>
                                        <span>Thêm sản phẩm</span>
                                    </div>
                                }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr class="spec-divider"><td colspan="5">Thông tin cơ bản</td></tr>
                    <tr class="spec-row">
                        <td class="col-label">Mức giá</td>
                        @for (int i = 0; i < maxLimit; i++)
                        {
                            <td class="spec-value">
                                @if (i < currentCount) { <strong>@Model[i].Price.ToString("N0") ₫</strong> } else { <span>—</span> }
                            </td>
                        }
                    </tr>
                    <tr class="spec-row">
                        <td class="col-label">Bảo hành</td>
                        @for (int i = 0; i < maxLimit; i++)
                        {
                            <td class="spec-value">
                                @if (i < currentCount) { @(Model[i].WarrantyPolicy ?? "12 tháng") } else { <span>—</span> }
                            </td>
                        }
                    </tr>

                    @if (allSpecs.Any())
                    {
                        <tr class="spec-divider"><td colspan="5">Cấu hình chi tiết</td></tr>
                        @foreach (var specName in allSpecs)
                        {
                            bool isDifferent = false;
                            if (currentCount > 1)
                            {
                                var values = Model.Select(p => p.Specifications.FirstOrDefault(s => s.SpecName == specName)?.SpecValue).ToList();
                                isDifferent = values.Where(v => v != null).Distinct().Count() > 1;
                            }

                            <tr class="spec-row @(isDifferent ? "highlight-diff" : "")">
                                <td class="col-label">@specName</td>
                                @for (int i = 0; i < maxLimit; i++)
                                {
                                    <td class="spec-value">
                                        @if (i < currentCount)
                                        {
                                            var val = Model[i].Specifications.FirstOrDefault(s => s.SpecName == specName)?.SpecValue;
                                            @(string.IsNullOrEmpty(val) ? "N/A" : val)
                                        }
                                        else { <span>—</span> }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (currentCount > 0)
        {
            <div class="cmp-footer-action">
                <form asp-action="ClearCompare" method="post">
                    <button type="submit" class="btn-wipe">
                        <i class="bi bi-trash3"></i> Làm trống danh sách
                    </button>
                </form>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        const searchInput = document.getElementById('cmpProductSearch');
        const suggestions = document.getElementById('searchSuggestions');

        function focusSearch() {
            if (searchInput) {
                searchInput.focus();
                window.scrollTo({ top: searchInput.offsetTop - 150, behavior: 'smooth' });
            }
        }

        if (searchInput) {
            searchInput.addEventListener('input', function() {
                const term = this.value.trim();
                if (term.length < 2) {
                    suggestions.style.display = 'none';
                    return;
                }

                $.getJSON('/Product/SearchProducts', { term: term }, function(data) {
                    if (data.length > 0) {
                        let html = '';
                        data.forEach(p => {
                            html += '<div class="search-result-item" onclick="addToCompare(' + p.id + ')">' +
                                    '<img src="' + p.image + '" alt="' + p.name + '">' +
                                    '<div class="search-result-info">' +
                                    '<h6>' + p.name + '</h6>' +
                                    '<span>' + p.price + '</span>' +
                                    '</div>' +
                                    '</div>';
                        });
                        suggestions.innerHTML = html;
                        suggestions.style.display = 'block';
                    } else {
                        suggestions.style.display = 'none';
                    }
                });
            });
        }

        document.addEventListener('click', function(e) {
            if (searchInput && suggestions && !searchInput.contains(e.target) && !suggestions.contains(e.target)) {
                suggestions.style.display = 'none';
            }
        });

        function addToCompare(id) {
            if (suggestions) suggestions.style.display = 'none';
            $.post('/Product/AddToCompareAjax', { productId: id }, function(res) {
                if (res.success) {
                    location.reload();
                } else {
                    Swal.fire({
                        icon: 'info',
                        title: 'Thông báo',
                        text: res.message,
                        confirmButtonColor: '#6366f1'
                    });
                }
            });
        }

        function removeFromCompare(id) {
             $.post('/Product/RemoveFromCompare', { productId: id }, function() {
                location.reload();
            });
        }
    </script>
}
