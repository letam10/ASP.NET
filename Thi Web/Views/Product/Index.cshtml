@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<TechShop.Models.Category>;
    int? activeCategory = ViewBag.Category as int?;
    int currentPage = ViewBag.Page is int p ? p : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    string currentSearch = ViewBag.Search as string ?? "";
    string currentSort = ViewBag.SortOrder as string ?? "";
    string currentPrice = ViewBag.PriceRange as string ?? "";

    var priceOptions = new Dictionary<string, string>
    {
        { "", "Tất cả mức giá" }, { "under5", "Dưới 5 triệu" }, { "5to10", "5 – 10 triệu" },
        { "10to15", "10 – 15 triệu" }, { "over15", "Trên 15 triệu" }
    };

    var catIcons = new Dictionary<string, string>
    {
        { "Laptop", "bi-laptop" }, { "Chuột", "bi-mouse" }, { "Bàn phím", "bi-keyboard" },
        { "Màn hình", "bi-display" }, { "Linh kiện PC", "bi-cpu" }, { "Tai nghe", "bi-headphones" },
        { "Ổ cứng", "bi-hdd" }, { "Ghế gaming", "bi-person-workspace" }
    };

    string catLabel = activeCategory.HasValue
        ? (categories?.FirstOrDefault(c => c.Id == activeCategory.Value)?.Name ?? "Sản phẩm")
        : "Tất cả sản phẩm";
}

<style>
    .shop-header {
        background: linear-gradient(135deg,#0f172a 0%,#1e293b 60%,#0f172a 100%);
        border-bottom: 1px solid rgba(99,102,241,.2);
        padding: 36px 0 28px;
        margin-top: 70px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden
    }

        .shop-header::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 80% at 10% 50%,rgba(99,102,241,.12) 0%,transparent 70%),radial-gradient(ellipse 40% 60% at 90% 30%,rgba(168,85,247,.09) 0%,transparent 70%);
            pointer-events: none
        }

        .shop-header .container {
            position: relative
        }

    .shop-header-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #818cf8;
        background: rgba(99,102,241,.12);
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 100px;
        padding: 4px 12px;
        margin-bottom: 12px
    }

    .shop-header-title {
        font-size: clamp(1.6rem,3vw,2.4rem);
        font-weight: 800;
        color: #f1f5f9;
        margin: 0 0 6px;
        line-height: 1.2;
        letter-spacing: -.02em
    }

        .shop-header-title .accent {
            background: linear-gradient(135deg,#818cf8 0%,#c084fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text
        }

    .shop-header-sub {
        color: #64748b;
        font-size: .9rem;
        margin: 0
    }

        .shop-header-sub strong {
            color: #94a3b8
        }

    .shop-layout {
        display: grid;
        grid-template-columns: 255px 1fr;
        gap: 24px;
        align-items: start;
        padding-bottom: 60px
    }
    @media

    (max-width:991px) {
        .shop-layout

    {
        grid-template-columns: 1fr
    }

    .shop-sidebar {
        display: none
    }

    }

    .shop-sidebar {
        position: sticky;
        top: 90px;
        display: flex;
        flex-direction: column;
        gap: 12px
    }

    .filter-card {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 16px;
        overflow: hidden;
        transition: border-color .2s
    }

        .filter-card:hover {
            border-color: rgba(99,102,241,.25)
        }

    .filter-card-head {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 16px;
        border-bottom: 1px solid rgba(255,255,255,.06);
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #94a3b8
    }

        .filter-card-head i {
            font-size: .85rem;
            color: #6366f1
        }

    .filter-card-body {
        padding: 10px
    }

    .search-wrap {
        position: relative
    }

        .search-wrap input {
            width: 100%;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.08);
            border-radius: 10px;
            color: #f1f5f9;
            font-size: .87rem;
            padding: 9px 38px 9px 13px;
            outline: none;
            transition: border-color .2s,background .2s
        }

            .search-wrap input::placeholder {
                color: #475569
            }

            .search-wrap input:focus {
                border-color: #6366f1;
                background: rgba(99,102,241,.07)
            }

        .search-wrap button {
            position: absolute;
            right: 11px;
            top: 50%;
            transform: translateY(-50%);
            background: none;
            border: none;
            color: #475569;
            cursor: pointer;
            padding: 0;
            font-size: .9rem;
            transition: color .2s
        }

            .search-wrap button:hover {
                color: #818cf8
            }

    .filter-nav {
        list-style: none;
        margin: 0;
        padding: 0
    }

        .filter-nav li + li {
            margin-top: 2px
        }

    .filter-nav-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 9px 10px;
        border-radius: 10px;
        font-size: .84rem;
        color: #94a3b8;
        text-decoration: none;
        transition: background .18s,color .18s
    }

        .filter-nav-item:hover {
            background: rgba(255,255,255,.05);
            color: #e2e8f0
        }

        .filter-nav-item.active {
            background: rgba(99,102,241,.14);
            color: #a5b4fc;
            font-weight: 600
        }

    .fi-left {
        display: flex;
        align-items: center;
        gap: 8px
    }

        .fi-left i {
            font-size: .82rem;
            opacity: .7
        }

    .shop-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 14px;
        padding: 12px 18px;
        margin-bottom: 22px
    }

    .toolbar-info {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        font-size: .82rem;
        color: #64748b
    }

    .toolbar-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .71rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 100px;
        background: rgba(99,102,241,.14);
        color: #818cf8;
        border: 1px solid rgba(99,102,241,.2)
    }

        .toolbar-tag.sec {
            background: rgba(100,116,139,.13);
            color: #94a3b8;
            border-color: rgba(100,116,139,.2)
        }

    .toolbar-count strong {
        color: #e2e8f0
    }

    .toolbar-sort {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .83rem
    }

        .toolbar-sort label {
            color: #64748b;
            white-space: nowrap;
            margin: 0
        }

    .sort-select {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 8px;
        color: #e2e8f0;
        font-size: .83rem;
        padding: 6px 10px;
        outline: none;
        cursor: pointer;
        transition: border-color .2s
    }

        .sort-select:focus {
            border-color: #6366f1
        }

        .sort-select option {
            background: #1e293b
        }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 18px
    }
    @media

    (max-width:768px) {
        .products-grid

    {
        grid-template-columns: repeat(2,1fr);
        gap: 12px
    }

    }

    .pcard {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform .28s cubic-bezier(.34,1.56,.64,1),border-color .25s,box-shadow .25s;
        position: relative
    }

        .pcard:hover {
            transform: translateY(-5px);
            border-color: rgba(99,102,241,.35);
            box-shadow: 0 20px 48px rgba(0,0,0,.38),0 0 0 1px rgba(99,102,241,.08)
        }

    .pcard-img-wrap {
        position: relative;
        overflow: hidden;
        background: #ffffff;
        aspect-ratio: 1/1
    }

    .pcard-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        display: block;
        padding: 10px;
        transition: transform .4s cubic-bezier(.25,.46,.45,.94)
    }

    .pcard:hover .pcard-img {
        transform: scale(1.06)
    }

    .pcard-overlay {
        position: absolute;
        inset: 0;
        background: rgba(15,23,42,.7);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity .25s
    }

    .pcard:hover .pcard-overlay {
        opacity: 1
    }

    .pcard-overlay-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #fff;
        color: #0f172a;
        border: none;
        border-radius: 100px;
        padding: 9px 20px;
        font-size: .82rem;
        font-weight: 700;
        text-decoration: none;
        transform: translateY(10px);
        transition: transform .28s cubic-bezier(.34,1.56,.64,1),background .2s
    }

    .pcard:hover .pcard-overlay-btn {
        transform: translateY(0)
    }

    .pcard-overlay-btn:hover {
        background: #e2e8f0;
        color: #0f172a
    }

    .pcard-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        z-index: 2;
        font-size: .67rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        padding: 3px 10px;
        border-radius: 100px
    }

        .pcard-badge.sale {
            background: #ef4444;
            color: #fff
        }

        .pcard-badge.out {
            background: rgba(71,85,105,.9);
            color: #e2e8f0
        }

    .pcard-body {
        padding: 14px 14px 12px;
        display: flex;
        flex-direction: column;
        flex: 1;
        gap: 4px
    }

    .pcard-brand {
        font-size: .68rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        color: #6366f1;
        margin: 0
    }

    .pcard-name {
        font-size: .88rem;
        font-weight: 600;
        color: #e2e8f0;
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden
    }

    .pcard-stars {
        display: flex;
        align-items: center;
        gap: 2px;
        font-size: .68rem;
        color: #f59e0b
    }

        .pcard-stars .star-count {
            color: #475569;
            font-size: .67rem;
            margin-left: 3px
        }

    .pcard-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 10px;
        border-top: 1px solid rgba(255,255,255,.05)
    }

    .pcard-price-wrap {
        display: flex;
        flex-direction: column;
        gap: 1px
    }

    .pcard-price {
        font-size: 1rem;
        font-weight: 800;
        color: #f1f5f9;
        letter-spacing: -.01em
    }

    .pcard-price-old {
        font-size: .72rem;
        color: #475569;
        text-decoration: line-through
    }

    .btn-cart {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        border: 1px solid rgba(99,102,241,.3);
        background: rgba(99,102,241,.1);
        color: #818cf8;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        cursor: pointer;
        transition: background .2s,border-color .2s,transform .15s,color .2s;
        flex-shrink: 0
    }

        .btn-cart:hover {
            background: #6366f1;
            border-color: #6366f1;
            color: #fff;
            transform: scale(1.1)
        }

        .btn-cart:disabled {
            opacity: .3;
            cursor: not-allowed;
            transform: none
        }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 80px 20px;
        text-align: center;
        background: #0f172a;
        border: 1px dashed rgba(255,255,255,.1);
        border-radius: 20px
    }

    .empty-icon {
        width: 70px;
        height: 70px;
        border-radius: 18px;
        background: rgba(99,102,241,.1);
        border: 1px solid rgba(99,102,241,.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.7rem;
        color: #6366f1;
        margin-bottom: 18px
    }

    .empty-state h4 {
        color: #e2e8f0;
        font-weight: 700;
        margin-bottom: 8px
    }

    .empty-state p {
        color: #475569;
        font-size: .9rem;
        margin-bottom: 20px
    }

    .btn-reset {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #6366f1;
        color: #fff;
        border-radius: 100px;
        padding: 10px 22px;
        font-size: .85rem;
        font-weight: 600;
        text-decoration: none;
        transition: background .2s,transform .15s
    }

        .btn-reset:hover {
            background: #4f46e5;
            transform: translateY(-1px);
            color: #fff
        }

    .pagination-wrap {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 36px
    }

    .page-btn {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .85rem;
        font-weight: 600;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.04);
        color: #94a3b8;
        transition: all .2s
    }

        .page-btn:hover {
            background: rgba(99,102,241,.15);
            border-color: rgba(99,102,241,.3);
            color: #a5b4fc
        }

        .page-btn.active {
            background: #6366f1;
            border-color: #6366f1;
            color: #fff
        }

        .page-btn.off {
            opacity: .3;
            pointer-events: none;
            cursor: default
        }</style>

<div class="shop-header">
    <div class="container">
        <div class="shop-header-label">
            <i class="bi @(activeCategory.HasValue && categories != null ? catIcons.GetValueOrDefault(categories.FirstOrDefault(c => c.Id == activeCategory.Value)?.Name ?? "", "bi-shop") : "bi-shop")"></i>
            TechShop Store
        </div>
        <h1 class="shop-header-title">
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <span>Kết quả cho "<span class="accent">@currentSearch</span>"</span>
            }
            else
            {
                <span class="accent">@catLabel</span>
            }
        </h1>
        <p class="shop-header-sub">
            Tìm thấy <strong>@Model.Count</strong> sản phẩm — Trang <strong>@currentPage</strong> / @totalPages
        </p>
    </div>
</div>

<div class="container">
    <div class="shop-layout">
        <aside class="shop-sidebar">
            <div class="filter-card">
                <div class="filter-card-head"><i class="bi bi-search"></i> Tìm kiếm</div>
                <div class="filter-card-body">
                    <form asp-controller="Product" asp-action="Index" method="get">
                        @if (activeCategory.HasValue)
                        {
                            <input type="hidden" name="category" value="@activeCategory" />
                        }
                        <div class="search-wrap">
                            <input type="text" name="search" placeholder="Tìm sản phẩm..." value="@currentSearch" />
                            <button type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="filter-card">
                <div class="filter-card-head"><i class="bi bi-grid"></i> Danh mục</div>
                <div class="filter-card-body">
                    <ul class="filter-nav">
                        <li>
                            <a asp-controller="Product" asp-action="Index" class="filter-nav-item @(!activeCategory.HasValue && string.IsNullOrEmpty(currentSearch) ? "active" : "")">
                                <span class="fi-left"><i class="bi bi-boxes"></i> Tất cả sản phẩm</span>
                            </a>
                        </li>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <li>
                                    <a asp-controller="Product" asp-action="Index" asp-route-category="@cat.Id" class="filter-nav-item @(activeCategory == cat.Id ? "active" : "")">
                                        <span class="fi-left"><i class="bi @catIcons.GetValueOrDefault(cat.Name, "bi-tag")"></i> @cat.Name</span>
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <div class="filter-card">
                <div class="filter-card-head"><i class="bi bi-cash-stack"></i> Mức giá</div>
                <div class="filter-card-body">
                    <ul class="filter-nav">
                        @foreach (var opt in priceOptions)
                        {
                            bool isActive = currentPrice == opt.Key || (opt.Key == "" && string.IsNullOrEmpty(currentPrice));
                            <li>
                                <a asp-controller="Product" asp-action="Index" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@opt.Key" asp-route-sortOrder="@currentSort" class="filter-nav-item @(isActive ? "active" : "")">
                                    <span class="fi-left"><i class="bi bi-currency-dollar"></i> @opt.Value</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </aside>

        <main>
            <div class="shop-toolbar">
                <div class="toolbar-info">
                    @if (activeCategory.HasValue)
                    {
                        <span class="toolbar-tag"><i class="bi bi-tag"></i> @catLabel</span>
                    }
                    @if (!string.IsNullOrEmpty(currentPrice))
                    {
                        <span class="toolbar-tag"><i class="bi bi-funnel-fill"></i> @priceOptions.GetValueOrDefault(currentPrice, "")</span>
                    }
                    @if (!string.IsNullOrEmpty(currentSearch))
                    {
                        <span class="toolbar-tag sec"><i class="bi bi-search"></i> "@currentSearch"</span>
                    }
                    <span class="toolbar-count"><strong>@Model.Count</strong> sản phẩm</span>
                </div>

                <form asp-controller="Product" asp-action="Index" method="get" class="toolbar-sort">
                    <input type="hidden" name="category" value="@activeCategory" />
                    <input type="hidden" name="search" value="@currentSearch" />
                    <input type="hidden" name="priceRange" value="@currentPrice" />
                    <label><i class="bi bi-sort-down me-1"></i>Sắp xếp</label>
                    <select name="sortOrder" class="sort-select" onchange="this.form.submit()">
                        <option value="" selected="@(currentSort == "")">Mới nhất</option>
                        <option value="price_asc" selected="@(currentSort == "price_asc")">Giá thấp → cao</option>
                        <option value="price_desc" selected="@(currentSort == "price_desc")">Giá cao → thấp</option>
                        <option value="name_asc" selected="@(currentSort == "name_asc")">Tên A → Z</option>
                        <option value="name_desc" selected="@(currentSort == "name_desc")">Tên Z → A</option>
                    </select>
                </form>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-search"></i></div>
                    <h4>Không tìm thấy sản phẩm</h4>
                    <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm khác</p>
                    <a asp-controller="Product" asp-action="Index" class="btn-reset">
                        <i class="bi bi-arrow-left"></i> Xem tất cả
                    </a>
                </div>
            }
            else
            {
                <div class="products-grid">
                    @foreach (var item in Model)
                    {
                        var rng = new Random(item.Id);
                        decimal rating = Math.Round((decimal)(rng.NextDouble() * 1.0 + 4.0), 1);
                        int fs = (int)Math.Floor(rating);
                        bool hh = (rating - fs) >= 0.5m;
                        int es = 5 - fs - (hh ? 1 : 0);

                        <div class="pcard">
                            <div class="pcard-img-wrap">
                                <img src="@(item.ImageUrl ?? "https://via.placeholder.com/300")" alt="@item.Name" class="pcard-img" loading="lazy" />
                                <div class="pcard-overlay">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.Id" class="pcard-overlay-btn">
                                        <i class="bi bi-eye"></i> Xem chi tiết
                                    </a>
                                </div>
                                @if (item.Stock == 0)
                                {
                                    <span class="pcard-badge out">Hết hàng</span>
                                }
                                else if (item.DiscountPrice.HasValue && item.DiscountPrice < item.Price)
                                {
                                    var pt = (int)Math.Round((1 - item.DiscountPrice.Value / item.Price) * 100);
                                    <span class="pcard-badge sale">-@pt%</span>
                                }
                            </div>
                            <div class="pcard-body">
                                <p class="pcard-brand">@item.Category?.Name</p>
                                <h6 class="pcard-name">@item.Name</h6>
                                <div class="pcard-stars">
                                    @for (int i = 0; i < fs; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    @if (hh)
                                    {
                                        <i class="bi bi-star-half"></i>
                                    }
                                    @for (int i = 0; i < es; i++)
                                    {
                                        <i class="bi bi-star" style="opacity:.35"></i>
                                    }
                                    <span class="star-count">@rating.ToString("N1")</span>
                                </div>
                                <div class="pcard-footer">
                                    <div class="pcard-price-wrap">
                                        <span class="pcard-price">@((item.DiscountPrice ?? item.Price).ToString("N0")) ₫</span>
                                        @if (item.DiscountPrice.HasValue && item.DiscountPrice < item.Price)
                                        {
                                            <span class="pcard-price-old">@item.Price.ToString("N0") ₫</span>
                                        }
                                    </div>
                                    @if (item.Stock > 0)
                                    {
                                        <form asp-controller="Product" asp-action="AddToCart" method="post" class="m-0 p-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <button type="submit" class="btn-cart" title="Thêm vào giỏ">
                                                <i class="bi bi-cart-plus"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn-cart" disabled title="Hết hàng"><i class="bi bi-cart-x"></i></button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (totalPages > 1)
                {
                    <div class="pagination-wrap">
                        @if (currentPage > 1)
                        {
                            <a asp-controller="Product" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@currentPrice" asp-route-sortOrder="@currentSort" class="page-btn"><i class="bi bi-chevron-left"></i></a>
                        }
                        else
                        {

                            <span class="page-btn off"><i class="bi bi-chevron-left"></i></span>
                        }

                        @for (int n = Math.Max(1, currentPage - 2); n <= Math.Min(totalPages, currentPage + 2); n++)
                        {
                            <a asp-controller="Product" asp-action="Index" asp-route-page="@n" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@currentPrice" asp-route-sortOrder="@currentSort" class="page-btn @(n == currentPage ? "active" : "")">@n</a>
                        }

                        @if (currentPage < totalPages)
                        {
                            <a asp-controller="Product" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@currentPrice" asp-route-sortOrder="@currentSort" class="page-btn"><i class="bi bi-chevron-right"></i></a>
                        }
                        else
                        {

                            <span class="page-btn off"><i class="bi bi-chevron-right"></i></span>
                        }
                    </div>
                }
            }
        </main>
    </div>
</div>