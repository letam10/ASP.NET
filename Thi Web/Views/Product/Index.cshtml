@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "Trang thiết bị | TechShop";
    var categories = ViewBag.Categories as List<TechShop.Models.Category>;
    int? activeCategory = ViewBag.Category as int?;
    int currentPage = ViewBag.Page is int p ? p : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    string currentSearch = ViewBag.Search as string ?? "";
    string currentSort = ViewBag.SortOrder as string ?? "";
    string currentPrice = ViewBag.PriceRange as string ?? "";

    var priceOptions = new Dictionary<string, string>
    {
        { "", "Tất cả mức giá" }, { "under5", "Dưới 5 triệu" }, { "5to10", "5 – 10 triệu" },
        { "10to15", "10 – 15 triệu" }, { "over15", "Trên 15 triệu" }
    };

    var catIcons = new Dictionary<string, string>
    {
        { "Laptop", "bi-laptop" }, { "Chuột", "bi-mouse" }, { "Bàn phím", "bi-keyboard" },
        { "Màn hình", "bi-display" }, { "Linh kiện PC", "bi-cpu" }, { "Tai nghe", "bi-headphones" },
        { "Ổ cứng", "bi-hdd" }, { "Ghế gaming", "bi-person-workspace" }
    };

    string catLabel = activeCategory.HasValue
        ? (categories?.FirstOrDefault(c => c.Id == activeCategory.Value)?.Name ?? "Sản phẩm")
        : "Tất cả thiết bị";
}

<style>
    :root {
        --shop-primary: #00f2ff;
        --shop-secondary: #7000ff;
        --shop-accent: #ff00c8;
    }

    .shop-header {
        background: var(--bg-dark);
        border-bottom: 1px solid var(--border);
        padding: 50px 0 40px;
        margin-top: 70px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
        background-image: 
            radial-gradient(circle at 10% 20%, rgba(0, 242, 255, 0.05) 0%, transparent 40%),
            radial-gradient(circle at 90% 80%, rgba(112, 0, 255, 0.05) 0%, transparent 40%);
    }

    .shop-header-label {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--shop-primary);
        background: rgba(0, 242, 255, 0.1);
        border: 1px solid rgba(0, 242, 255, 0.2);
        border-radius: 100px;
        padding: 6px 16px;
        margin-bottom: 15px;
    }

    .shop-header-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 900;
        color: var(--text-primary);
        margin-bottom: 10px;
        letter-spacing: -1px;
    }

    .shop-header-title .accent {
        background: linear-gradient(90deg, var(--shop-primary), var(--shop-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .shop-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 30px;
        align-items: start;
        padding-bottom: 80px;
    }

    @@media (max-width: 991px) {
        .shop-layout { grid-template-columns: 1fr; }
        .shop-sidebar { display: none; }
    }

    .shop-sidebar {
        position: sticky;
        top: 100px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .filter-card {
        background: var(--bg-card);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border);
        border-radius: 24px;
        overflow: hidden;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .filter-card:hover {
        border-color: rgba(0, 242, 255, 0.3);
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    }

    .filter-card-head {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 18px 20px;
        border-bottom: 1px solid var(--border);
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--text-muted);
    }

    .filter-card-head i { color: var(--shop-primary); font-size: 1rem; }

    .filter-card-body { padding: 15px; }

    .search-wrap { position: relative; }
    .search-wrap input {
        width: 100%;
        background: var(--input-bg);
        border: 1px solid var(--border);
        border-radius: 15px;
        color: var(--text-primary);
        font-size: 0.9rem;
        padding: 12px 45px 12px 15px;
        transition: all 0.3s;
    }
    .search-wrap input:focus {
        border-color: var(--shop-primary);
        background: var(--bg-card);
        box-shadow: 0 0 15px rgba(0, 242, 255, 0.1);
    }
    .search-wrap button {
        position: absolute; right: 15px; top: 50%; transform: translateY(-50%);
        background: none; border: none; color: var(--text-muted); font-size: 1.1rem;
    }

    .filter-nav { list-style: none; padding: 0; margin: 0; }
    .filter-nav-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 15px; border-radius: 12px;
        color: var(--text-muted); text-decoration: none;
        transition: all 0.2s; font-size: 0.9rem; font-weight: 500;
    }
    .filter-nav-item:hover { background: rgba(var(--bs-primary-rgb), 0.05); color: var(--text-primary); }
    .filter-nav-item.active { background: rgba(0, 242, 255, 0.1); color: var(--shop-primary); font-weight: 700; }

    /* TOOLBAR */
    .shop-toolbar {
        display: flex; align-items: center; justify-content: space-between;
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: 20px; padding: 15px 25px; margin-bottom: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .toolbar-info { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .toolbar-tag {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 5px 12px; border-radius: 100px;
        background: rgba(var(--bs-primary-rgb), 0.1);
        border: 1px solid rgba(var(--bs-primary-rgb), 0.2);
        color: var(--primary); font-size: 0.75rem; font-weight: 700;
    }

    .sort-select {
        background: var(--input-bg); border: 1px solid var(--border);
        border-radius: 12px; color: var(--text-primary); padding: 8px 15px;
        font-size: 0.9rem; outline: none; cursor: pointer;
    }

    /* GRID & CARDS */
    .products-grid {
        display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 25px;
    }

    .pcard {
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: 24px; overflow: hidden; display: flex; flex-direction: column;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative; height: 100%;
    }

    .pcard:hover {
        transform: translateY(-10px);
        border-color: var(--shop-primary);
        box-shadow: 0 20px 50px rgba(0,0,0,0.2), 0 0 20px rgba(0, 242, 255, 0.1);
    }

    .pcard-img-wrap {
        aspect-ratio: 1/1; position: relative; overflow: hidden;
        background: #fff; padding: 20px;
    }

    .pcard-img { width: 100%; height: 100%; object-fit: contain; transition: transform 0.5s ease; }
    .pcard:hover .pcard-img { transform: scale(1.1); }

    .pcard-overlay {
        position: absolute; inset: 0; background: rgba(0,0,0,0.6);
        backdrop-filter: blur(5px); display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: all 0.3s;
    }
    .pcard:hover .pcard-overlay { opacity: 1; }

    .pcard-overlay-btn {
        background: #fff; color: #000; border-radius: 100px; padding: 10px 25px;
        font-weight: 800; text-decoration: none; transform: translateY(20px); transition: all 0.4s;
    }
    .pcard:hover .pcard-overlay-btn { transform: translateY(0); }

    .pcard-badge {
        position: absolute; top: 15px; left: 15px; z-index: 5;
        font-size: 0.7rem; font-weight: 800; padding: 4px 12px; border-radius: 100px;
        text-transform: uppercase;
    }
    .pcard-badge.sale { background: var(--shop-accent); color: #fff; box-shadow: 0 0 10px var(--shop-accent); }
    .pcard-badge.out { background: #64748b; color: #fff; }

    .wishlist-btn {
        position: absolute; top: 15px; right: 15px; z-index: 10;
        width: 40px; height: 40px; border-radius: 50%;
        background: rgba(0,0,0,0.4); backdrop-filter: blur(5px);
        border: 1px solid rgba(255,255,255,0.1); color: #fff;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s;
    }
    .wishlist-btn:hover { background: var(--shop-accent); color: #fff; transform: scale(1.1); }
    .wishlist-btn.active { background: var(--shop-accent); color: #fff; }

    .pcard-body { padding: 20px; flex-grow: 1; display: flex; flex-direction: column; }
    .pcard-brand { color: var(--shop-primary); font-size: 0.7rem; font-weight: 800; text-transform: uppercase; margin-bottom: 5px; }
    .pcard-name { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 10px; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; min-height: 2.8em; }
    
    .pcard-stars { color: #ffb800; font-size: 0.8rem; margin-bottom: 15px; display: flex; align-items: center; gap: 3px; }
    .star-count { color: var(--text-muted); font-size: 0.75rem; margin-left: 5px; font-weight: 600; }

    .pcard-footer { display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--border); pt: 15px; margin-top: auto; padding-top: 15px; }
    .pcard-price { font-size: 1.2rem; font-weight: 800; color: var(--text-primary); }
    .pcard-price-old { font-size: 0.85rem; color: var(--text-muted); text-decoration: line-through; display: block; }

    .btn-cart {
        width: 44px; height: 44px; border-radius: 15px;
        background: rgba(0, 242, 255, 0.1); border: 1px solid rgba(0, 242, 255, 0.2);
        color: var(--shop-primary); transition: all 0.3s;
    }
    .btn-cart:hover:not(:disabled) { background: var(--shop-primary); color: #000; box-shadow: 0 0 20px rgba(0, 242, 255, 0.4); transform: scale(1.05); }

    /* PAGINATION */
    .pagination-wrap { display: flex; justify-content: center; gap: 10px; margin-top: 50px; }
    .page-btn {
        width: 45px; height: 45px; border-radius: 15px; display: flex; align-items: center; justify-content: center;
        background: var(--bg-card); border: 1px solid var(--border); color: var(--text-muted);
        text-decoration: none; font-weight: 700; transition: all 0.3s;
    }
    .page-btn:hover:not(.active) { border-color: var(--shop-primary); color: var(--shop-primary); background: rgba(0, 242, 255, 0.05); }
    .page-btn.active { background: var(--shop-primary); border-color: var(--shop-primary); color: #000; box-shadow: 0 0 15px rgba(0, 242, 255, 0.3); }

    .empty-state {
        text-align: center; padding: 100px 40px; background: var(--bg-card); border: 2px dashed var(--border); border-radius: 30px;
    }
    .empty-icon { font-size: 4rem; color: var(--shop-primary); opacity: 0.5; margin-bottom: 20px; }
    .btn-cyber-reset {
        display: inline-flex; align-items: center; gap: 10px;
        padding: 12px 30px; border-radius: 100px; background: var(--shop-primary); color: #000;
        font-weight: 800; text-decoration: none; transition: all 0.3s;
    }
    .btn-cyber-reset:hover { box-shadow: 0 0 20px var(--shop-primary); transform: translateY(-3px); }
</style>

<div class="shop-header">
    <div class="container">
        <div class="shop-header-label">
            <i class="bi @(activeCategory.HasValue && categories != null ? catIcons.GetValueOrDefault(categories.FirstOrDefault(c => c.Id == activeCategory.Value)?.Name ?? "", "bi-shop") : "bi-shop")"></i>
            Hệ sinh thái TechShop
        </div>
        <h1 class="shop-header-title">
            @if (!string.IsNullOrEmpty(currentSearch))
            {
                <span>Quét dữ liệu: <span class="accent">"@currentSearch"</span></span>
            }
            else
            {
                <span>Khám phá <span class="accent">@catLabel</span></span>
            }
        </h1>
        <p class="text-muted">
            Tìm thấy <strong>@Model.Count</strong> sản phẩm — Hiển thị trang @currentPage
        </p>
    </div>
</div>

<div class="container">
    <div class="shop-layout">
        <aside class="shop-sidebar">
            <div class="filter-card">
                <div class="filter-card-head"><i class="bi bi-search"></i> Tìm kiếm nhanh</div>
                <div class="filter-card-body">
                    <form asp-controller="Product" asp-action="Index" method="get">
                        @if (activeCategory.HasValue) { <input type="hidden" name="category" value="@activeCategory" /> }
                        <div class="search-wrap">
                            <input type="text" name="search" placeholder="Mã hiệu/Tên thiết bị..." value="@currentSearch" />
                            <button type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="filter-card">
                <div class="filter-card-head"><i class="bi bi-grid"></i> Danh mục sản phẩm</div>
                <div class="filter-card-body">
                    <ul class="filter-nav">
                        <li>
                            <a asp-controller="Product" asp-action="Index" class="filter-nav-item @(!activeCategory.HasValue && string.IsNullOrEmpty(currentSearch) ? "active" : "")">
                                <i class="bi bi-lightning-charge"></i> Tất cả thiết bị
                            </a>
                        </li>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <li>
                                    <a asp-controller="Product" asp-action="Index" asp-route-category="@cat.Id" class="filter-nav-item @(activeCategory == cat.Id ? "active" : "")">
                                        <i class="bi @catIcons.GetValueOrDefault(cat.Name, "bi-tag")"></i> @cat.Name
                                    </a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            </div>

            <div class="filter-card">
                <div class="filter-card-head"><i class="bi bi-bar-chart"></i> Khoảng giá</div>
                <div class="filter-card-body">
                    <ul class="filter-nav">
                        @foreach (var opt in priceOptions)
                        {
                            bool isActive = currentPrice == opt.Key || (opt.Key == "" && string.IsNullOrEmpty(currentPrice));
                            <li>
                                <a asp-controller="Product" asp-action="Index" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@opt.Key" asp-route-sortOrder="@currentSort" class="filter-nav-item @(isActive ? "active" : "")">
                                    <i class="bi bi-shield-check"></i> @opt.Value
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </aside>

        <main>
            <div class="shop-toolbar">
                <div class="toolbar-info">
                    @if (activeCategory.HasValue) { <span class="toolbar-tag">@catLabel</span> }
                    @if (!string.IsNullOrEmpty(currentSearch)) { <span class="toolbar-tag border-info">Search: @currentSearch</span> }
                    <span class="text-muted small ms-2">Lọc: <strong>@Model.Count</strong> kết quả</span>
                </div>

                <form asp-controller="Product" asp-action="Index" method="get" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="category" value="@activeCategory" />
                    <input type="hidden" name="search" value="@currentSearch" />
                    <input type="hidden" name="priceRange" value="@currentPrice" />
                    <select name="sortOrder" class="sort-select" onchange="this.form.submit()">
                        <option value="" selected="@(currentSort == "")">Ưu tiên mới nhất</option>
                        <option value="price_asc" selected="@(currentSort == "price_asc")">Giá thấp → cao</option>
                        <option value="price_desc" selected="@(currentSort == "price_desc")">Giá cao → thấp</option>
                        <option value="name_asc" selected="@(currentSort == "name_asc")">Tên định danh A-Z</option>
                    </select>
                </form>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-robot empty-icon"></i>
                    <h3>Hệ thống không tìm thấy sản phẩm khả dụng</h3>
                    <p class="text-muted mb-4">Vui lòng thử điều chỉnh tham số lọc hoặc đổi từ khóa tìm kiếm của bạn.</p>
                    <a asp-action="Index" class="btn-cyber-reset">
                        <i class="bi bi-arrow-repeat"></i> Khởi động lại quét
                    </a>
                </div>
            }
            else
            {
                <div class="products-grid">
                    @foreach (var item in Model)
                    {
                        var rng = new Random(item.Id);
                        decimal rating = Math.Round((decimal)(rng.NextDouble() * 1.0 + 4.0), 1);
                        int fs = (int)Math.Floor(rating);
                        bool hh = (rating - fs) >= 0.5m;
                        int es = 5 - fs - (hh ? 1 : 0);

                        <div class="pcard">
                            <button type="button" class="wishlist-btn" onclick="toggleWishlist(@item.Id, this)" title="Thêm vào danh sách theo dõi">
                                <i class="bi bi-heart"></i>
                            </button>
                            <div class="pcard-img-wrap">
                                <img src="@(item.ImageUrl ?? "https://via.placeholder.com/300")" alt="@item.Name" class="pcard-img" loading="lazy" />
                                <div class="pcard-overlay">
                                    <a asp-controller="Product" asp-action="Detail" asp-route-id="@item.Id" class="pcard-overlay-btn">
                                        CHI TIẾT
                                    </a>
                                </div>
                                @if (item.Stock == 0) { <span class="pcard-badge out">Hết linh kiện</span> }
                                else if (item.DiscountPrice.HasValue && item.DiscountPrice < item.Price)
                                {
                                    var pt = (int)Math.Round((1 - item.DiscountPrice.Value / item.Price) * 100);
                                    <span class="pcard-badge sale">-@pt% PROMO</span>
                                }
                            </div>
                            <div class="pcard-body">
                                <p class="pcard-brand">@item.Category?.Name</p>
                                <h6 class="pcard-name">@item.Name</h6>
                                <div class="pcard-stars">
                                    @for (int i = 0; i < fs; i++) { <i class="bi bi-star-fill"></i> }
                                    @if (hh) { <i class="bi bi-star-half"></i> }
                                    @for (int i = 0; i < es; i++) { <i class="bi bi-star" style="opacity:0.2"></i> }
                                    <span class="star-count">@rating.ToString("N1") Signal</span>
                                </div>
                                <div class="pcard-footer">
                                    <div class="pcard-price-wrap">
                                        <span class="pcard-price">@((item.DiscountPrice ?? item.Price).ToString("N0")) ₫</span>
                                        @if (item.DiscountPrice.HasValue && item.DiscountPrice < item.Price)
                                        {
                                            <span class="pcard-price-old">@item.Price.ToString("N0") ₫</span>
                                        }
                                    </div>
                                    @if (item.Stock > 0)
                                    {
                                        <form asp-controller="Product" asp-action="AddToCart" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <button type="submit" class="btn-cart" title="Trình nạp giỏ hàng">
                                                <i class="bi bi-plus-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn-cart" disabled title="Thiếu linh kiện"><i class="bi bi-slash-circle"></i></button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (totalPages > 1)
                {
                    <div class="pagination-wrap">
                        @if (currentPage > 1)
                        {
                            <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@currentPrice" asp-route-sortOrder="@currentSort" class="page-btn"><i class="bi bi-chevron-left"></i></a>
                        }

                        @for (int n = Math.Max(1, currentPage - 2); n <= Math.Min(totalPages, currentPage + 2); n++)
                        {
                            <a asp-action="Index" asp-route-page="@n" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@currentPrice" asp-route-sortOrder="@currentSort" class="page-btn @(n == currentPage ? "active" : "")">@n</a>
                        }

                        @if (currentPage < totalPages)
                        {
                            <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-category="@activeCategory" asp-route-search="@currentSearch" asp-route-priceRange="@currentPrice" asp-route-sortOrder="@currentSort" class="page-btn"><i class="bi bi-chevron-right"></i></a>
                        }
                    </div>
                }
            }
        </main>
    </div>
</div>