@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<TechShop.Models.Category>;

    var priceOptions = new Dictionary<string, string>
    {
        { "", "Tất cả mức giá" },
        { "under5", "Dưới 5 triệu" },
        { "5to10", "5 – 10 triệu" },
        { "10to15", "10 – 15 triệu" },
        { "over15", "Trên 15 triệu" }
    };
}

<style>
    /* =============================================
       PAGE HEADER
    ============================================= */
    .shop-header {
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f172a 100%);
        border-bottom: 1px solid rgba(99,102,241,.2);
        padding: 36px 0 28px;
        margin-top: 70px;
        margin-bottom: 36px;
        position: relative;
        overflow: hidden;
    }

    .shop-header::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            radial-gradient(ellipse 60% 80% at 10% 50%, rgba(99,102,241,.12) 0%, transparent 70%),
            radial-gradient(ellipse 40% 60% at 90% 30%, rgba(168,85,247,.09) 0%, transparent 70%);
        pointer-events: none;
    }

    .shop-header .container { position: relative; }

    .shop-header-label {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #818cf8;
        background: rgba(99,102,241,.12);
        border: 1px solid rgba(99,102,241,.25);
        border-radius: 100px;
        padding: 4px 12px;
        margin-bottom: 12px;
    }

    .shop-header-title {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        font-weight: 800;
        color: #f1f5f9;
        margin: 0 0 6px;
        line-height: 1.2;
        letter-spacing: -.02em;
    }

    .shop-header-title .accent {
        background: linear-gradient(135deg, #818cf8 0%, #c084fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .shop-header-sub {
        color: #64748b;
        font-size: .9rem;
        margin: 0;
    }

    .shop-header-sub strong { color: #94a3b8; }

    /* =============================================
       LAYOUT
    ============================================= */
    .shop-layout {
        display: grid;
        grid-template-columns: 255px 1fr;
        gap: 24px;
        align-items: start;
        padding-bottom: 60px;
    }

    @@media (max-width: 991px) {
        .shop-layout { grid-template-columns: 1fr; }
        .shop-sidebar { display: none; }
    }

    /* =============================================
       SIDEBAR
    ============================================= */
    .shop-sidebar {
        position: sticky;
        top: 90px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .filter-card {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 16px;
        overflow: hidden;
        transition: border-color .2s;
    }

    .filter-card:hover { border-color: rgba(99,102,241,.25); }

    .filter-card-head {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 16px;
        border-bottom: 1px solid rgba(255,255,255,.06);
        font-size: .72rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #94a3b8;
    }

    .filter-card-head i { font-size: .85rem; color: #6366f1; }

    .filter-card-body { padding: 10px; }

    /* Search */
    .search-wrap { position: relative; }

    .search-wrap input {
        width: 100%;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 10px;
        color: #f1f5f9;
        font-size: .87rem;
        padding: 9px 38px 9px 13px;
        outline: none;
        transition: border-color .2s, background .2s;
    }

    .search-wrap input::placeholder { color: #475569; }
    .search-wrap input:focus { border-color: #6366f1; background: rgba(99,102,241,.07); }

    .search-wrap button {
        position: absolute;
        right: 11px; top: 50%;
        transform: translateY(-50%);
        background: none; border: none;
        color: #475569; cursor: pointer; padding: 0;
        font-size: .9rem;
        transition: color .2s;
    }
    .search-wrap button:hover { color: #818cf8; }

    /* Nav list */
    .filter-nav { list-style: none; margin: 0; padding: 0; }
    .filter-nav li + li { margin-top: 2px; }

    .filter-nav-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        padding: 9px 10px;
        border-radius: 10px;
        font-size: .84rem;
        color: #94a3b8;
        text-decoration: none;
        transition: background .18s, color .18s;
    }

    .filter-nav-item:hover { background: rgba(255,255,255,.05); color: #e2e8f0; }

    .filter-nav-item.active {
        background: rgba(99,102,241,.14);
        color: #a5b4fc;
        font-weight: 600;
    }

    .fi-left { display: flex; align-items: center; gap: 8px; }
    .fi-left i { font-size: .82rem; opacity: .7; }

    .filter-badge {
        font-size: .67rem;
        font-weight: 700;
        background: rgba(255,255,255,.07);
        color: #64748b;
        border-radius: 100px;
        padding: 2px 7px;
    }

    .filter-nav-item.active .filter-badge {
        background: rgba(99,102,241,.22);
        color: #818cf8;
    }

    /* =============================================
       TOOLBAR
    ============================================= */
    .shop-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 14px;
        padding: 12px 18px;
        margin-bottom: 22px;
    }

    .toolbar-info {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        font-size: .82rem;
        color: #64748b;
    }

    .toolbar-tag {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: .71rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 100px;
        background: rgba(99,102,241,.14);
        color: #818cf8;
        border: 1px solid rgba(99,102,241,.2);
    }

    .toolbar-tag.sec {
        background: rgba(100,116,139,.13);
        color: #94a3b8;
        border-color: rgba(100,116,139,.2);
    }

    .toolbar-count strong { color: #e2e8f0; }

    .toolbar-sort {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: .83rem;
    }

    .toolbar-sort label { color: #64748b; white-space: nowrap; margin: 0; }

    .sort-select {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 8px;
        color: #e2e8f0;
        font-size: .83rem;
        padding: 6px 10px;
        outline: none;
        cursor: pointer;
        transition: border-color .2s;
    }

    .sort-select:focus { border-color: #6366f1; }
    .sort-select option { background: #1e293b; }

    /* =============================================
       PRODUCT GRID
    ============================================= */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    @@media (max-width: 768px) {
        .products-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    }

    /* =============================================
       PRODUCT CARD
    ============================================= */
    .pcard {
        background: #0f172a;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 18px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform .28s cubic-bezier(.34,1.56,.64,1),
                    border-color .25s, box-shadow .25s;
        position: relative;
    }

    .pcard:hover {
        transform: translateY(-5px);
        border-color: rgba(99,102,241,.35);
        box-shadow: 0 20px 48px rgba(0,0,0,.38), 0 0 0 1px rgba(99,102,241,.08);
    }

    .pcard-img-wrap {
        position: relative;
        overflow: hidden;
        background: #1e293b;
        aspect-ratio: 4 / 3;
    }

    .pcard-img {
        width: 100%; height: 100%;
        object-fit: cover; display: block;
        transition: transform .4s cubic-bezier(.25,.46,.45,.94);
    }

    .pcard:hover .pcard-img { transform: scale(1.07); }

    .pcard-overlay {
        position: absolute; inset: 0;
        background: rgba(15,23,42,.65);
        backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: opacity .25s;
    }

    .pcard:hover .pcard-overlay { opacity: 1; }

    .pcard-overlay-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #fff; color: #0f172a;
        border: none; border-radius: 100px;
        padding: 9px 20px;
        font-size: .82rem; font-weight: 700;
        text-decoration: none;
        transform: translateY(10px);
        transition: transform .28s cubic-bezier(.34,1.56,.64,1), background .2s;
    }

    .pcard:hover .pcard-overlay-btn { transform: translateY(0); }
    .pcard-overlay-btn:hover { background: #e2e8f0; color: #0f172a; }

    .pcard-stock-badge {
        position: absolute;
        top: 11px; left: 11px;
        font-size: .67rem; font-weight: 700;
        letter-spacing: .06em; text-transform: uppercase;
        padding: 3px 10px; border-radius: 100px;
    }

    .pcard-stock-badge.out {
        background: rgba(239,68,68,.15);
        color: #f87171;
        border: 1px solid rgba(239,68,68,.25);
    }

    .pcard-stock-badge.low {
        background: rgba(245,158,11,.15);
        color: #fbbf24;
        border: 1px solid rgba(245,158,11,.25);
    }

    .pcard-body {
        padding: 15px 15px 13px;
        display: flex; flex-direction: column;
        flex: 1; gap: 5px;
    }

    .pcard-category {
        font-size: .68rem; font-weight: 700;
        letter-spacing: .08em; text-transform: uppercase;
        color: #6366f1; margin: 0;
    }

    .pcard-name {
        font-size: .9rem; font-weight: 600;
        color: #e2e8f0; margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .pcard-stars {
        display: flex; align-items: center; gap: 2px;
        font-size: .7rem; color: #f59e0b;
    }

    .pcard-stars .star-count { color: #475569; font-size: .68rem; margin-left: 3px; }

    .pcard-footer {
        display: flex; align-items: center;
        justify-content: space-between;
        margin-top: auto; padding-top: 10px;
        border-top: 1px solid rgba(255,255,255,.05);
    }

    .pcard-price {
        font-size: 1.05rem; font-weight: 800;
        color: #f1f5f9; letter-spacing: -.01em;
    }

    .btn-cart {
        width: 36px; height: 36px;
        border-radius: 10px;
        border: 1px solid rgba(99,102,241,.3);
        background: rgba(99,102,241,.1);
        color: #818cf8;
        display: flex; align-items: center; justify-content: center;
        font-size: .95rem; cursor: pointer;
        transition: background .2s, border-color .2s, transform .15s, color .2s;
        flex-shrink: 0;
    }

    .btn-cart:hover {
        background: #6366f1; border-color: #6366f1;
        color: #fff; transform: scale(1.1);
    }

    .btn-cart:disabled { opacity: .3; cursor: not-allowed; transform: none; }

    /* =============================================
       EMPTY STATE
    ============================================= */
    .empty-state {
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        padding: 80px 20px; text-align: center;
        background: #0f172a;
        border: 1px dashed rgba(255,255,255,.1);
        border-radius: 20px;
    }

    .empty-icon {
        width: 70px; height: 70px; border-radius: 18px;
        background: rgba(99,102,241,.1);
        border: 1px solid rgba(99,102,241,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.7rem; color: #6366f1; margin-bottom: 18px;
    }

    .empty-state h4 { color: #e2e8f0; font-weight: 700; margin-bottom: 8px; }
    .empty-state p { color: #475569; font-size: .9rem; margin-bottom: 20px; }

    .btn-reset {
        display: inline-flex; align-items: center; gap: 7px;
        background: #6366f1; color: #fff;
        border-radius: 100px; padding: 10px 22px;
        font-size: .85rem; font-weight: 600;
        text-decoration: none;
        transition: background .2s, transform .15s;
    }

    .btn-reset:hover { background: #4f46e5; transform: translateY(-1px); color: #fff; }
</style>

<!-- ===== PAGE HEADER ===== -->
<div class="shop-header">
    <div class="container">
        <div class="shop-header-label">
            <i class="bi bi-shop"></i> TechShop Store
        </div>
        <h1 class="shop-header-title">
            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
            {
                <span>Kết quả cho "<span class="accent">@ViewBag.Search</span>"</span>
            }
            else if (ViewBag.SelectedCategory != null)
            {
                <span class="accent">@categories?.FirstOrDefault(c => c.Id == (int)ViewBag.SelectedCategory)?.Name</span>
            }
            else
            {
                <span>Tất cả <span class="accent">sản phẩm</span></span>
            }
        </h1>
        <p class="shop-header-sub">Tìm thấy <strong>@Model.Count</strong> sản phẩm phù hợp</p>
    </div>
</div>

<!-- ===== MAIN CONTENT ===== -->
<div class="container">
    <div class="shop-layout">

        <!-- ===== SIDEBAR ===== -->
        <aside class="shop-sidebar">

            <!-- Tìm kiếm -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <i class="bi bi-search"></i> Tìm kiếm
                </div>
                <div class="filter-card-body">
                    <form asp-controller="Product" asp-action="Index" method="get">
                        @if (ViewBag.SelectedCategory != null)
                        {
                            <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategory" />
                        }
                        <div class="search-wrap">
                            <input type="text" name="search"
                                   placeholder="Tìm sản phẩm..."
                                   value="@ViewBag.Search" />
                            <button type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Danh mục -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <i class="bi bi-grid"></i> Danh mục
                </div>
                <div class="filter-card-body">
                    <ul class="filter-nav">
                        <li>
                            <a asp-controller="Product" asp-action="Index"
                               class="filter-nav-item @(ViewBag.SelectedCategory == null && string.IsNullOrEmpty(ViewBag.Search as string) ? "active" : "")">
                                <span class="fi-left">
                                    <i class="bi bi-grid-3x3-gap"></i> Tất cả sản phẩm
                                </span>
                            </a>
                        </li>
                        @foreach (var cat in categories!)
                        {
                            <li>
                                <a asp-controller="Product" asp-action="Index"
                                   asp-route-categoryId="@cat.Id"
                                   class="filter-nav-item @(ViewBag.SelectedCategory?.ToString() == cat.Id.ToString() ? "active" : "")">
                                    <span class="fi-left">
                                        <i class="bi bi-tag"></i> @cat.Name
                                    </span>
                                    <span class="filter-badge">@cat.Products.Count</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Lọc giá -->
            <div class="filter-card">
                <div class="filter-card-head">
                    <i class="bi bi-cash-stack"></i> Mức giá
                </div>
                <div class="filter-card-body">
                    <ul class="filter-nav">
                        @foreach (var opt in priceOptions)
                        {
                            <li>
                                <a asp-controller="Product" asp-action="Index"
                                   asp-route-categoryId="@ViewBag.SelectedCategory"
                                   asp-route-search="@ViewBag.Search"
                                   asp-route-priceRange="@opt.Key"
                                   asp-route-sortOrder="@ViewBag.SortOrder"
                                   class="filter-nav-item @(ViewBag.PriceRange?.ToString() == opt.Key ? "active" : (opt.Key == "" && ViewBag.PriceRange == null ? "active" : ""))">
                                    <span class="fi-left">
                                        <i class="bi bi-currency-dollar"></i> @opt.Value
                                    </span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

        </aside>

        <!-- ===== PRODUCT AREA ===== -->
        <main>

            <!-- Toolbar -->
            <div class="shop-toolbar">
                <div class="toolbar-info">
                    @if (!string.IsNullOrEmpty(ViewBag.PriceRange as string))
                    {
                        <span class="toolbar-tag">
                            <i class="bi bi-funnel-fill"></i>
                            @priceOptions.GetValueOrDefault(ViewBag.PriceRange as string ?? "", "")
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                    {
                        <span class="toolbar-tag sec">
                            <i class="bi bi-search"></i> "@ViewBag.Search"
                        </span>
                    }
                    <span class="toolbar-count"><strong>@Model.Count</strong> sản phẩm</span>
                </div>

                <form asp-controller="Product" asp-action="Index" method="get" class="toolbar-sort">
                    <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategory" />
                    <input type="hidden" name="search" value="@ViewBag.Search" />
                    <input type="hidden" name="priceRange" value="@ViewBag.PriceRange" />
                    <label><i class="bi bi-sort-down me-1"></i>Sắp xếp</label>
                    <select name="sortOrder" class="sort-select" onchange="this.form.submit()">
                        <option value="" selected="@(ViewBag.SortOrder == null)">Mới nhất</option>
                        <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Giá thấp → cao</option>
                        <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Giá cao → thấp</option>
                        <option value="name_asc" selected="@(ViewBag.SortOrder == "name_asc")">Tên A → Z</option>
                    </select>
                </form>
            </div>

            <!-- Product Grid / Empty -->
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon"><i class="bi bi-search"></i></div>
                    <h4>Không tìm thấy sản phẩm</h4>
                    <p>Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm khác</p>
                    <a asp-controller="Product" asp-action="Index" class="btn-reset">
                        <i class="bi bi-arrow-left"></i> Xem tất cả sản phẩm
                    </a>
                </div>
            }
            else
            {
                <div class="products-grid">
                    @foreach (var product in Model)
                    {
                        var rng = new Random(product.Id);
                        decimal fakeRating = Math.Round((decimal)(rng.NextDouble() * 1.0 + 4.0), 1);
                        int fakeReviews = rng.Next(12, 345);
                        int fullStars = (int)Math.Floor(fakeRating);
                        bool hasHalf = (fakeRating - fullStars) >= 0.5m;
                        int emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

                        <div class="pcard">
                            <div class="pcard-img-wrap">
                                <img src="@(product.ImageUrl ?? "https://via.placeholder.com/400x300")"
                                     alt="@product.Name"
                                     class="pcard-img"
                                     loading="lazy" />

                                <div class="pcard-overlay">
                                    <a asp-controller="Product" asp-action="Detail"
                                       asp-route-id="@product.Id"
                                       class="pcard-overlay-btn">
                                        <i class="bi bi-eye"></i> Xem chi tiết
                                    </a>
                                </div>

                                @if (product.Stock == 0)
                                {
                                    <span class="pcard-stock-badge out">Hết hàng</span>
                                }
                                else if (product.Stock < 5)
                                {
                                    <span class="pcard-stock-badge low">Sắp hết</span>
                                }
                            </div>

                            <div class="pcard-body">
                                <p class="pcard-category">@product.Category?.Name</p>
                                <h6 class="pcard-name">@product.Name</h6>

                                <div class="pcard-stars">
                                    @for (int i = 0; i < fullStars; i++) { <i class="bi bi-star-fill"></i> }
                                    @if (hasHalf) { <i class="bi bi-star-half"></i> }
                                    @for (int i = 0; i < emptyStars; i++) { <i class="bi bi-star" style="opacity:.35"></i> }
                                    <span class="star-count">(@fakeReviews)</span>
                                </div>

                                <div class="pcard-footer">
                                    <span class="pcard-price">@product.Price.ToString("N0") ₫</span>
                                    @if (product.Stock > 0)
                                    {
                                        <form asp-controller="Product" asp-action="AddToCart" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@product.Id" />
                                            <button type="submit" class="btn-cart" title="Thêm vào giỏ hàng">
                                                <i class="bi bi-cart-plus"></i>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn-cart" disabled title="Hết hàng">
                                            <i class="bi bi-cart-x"></i>
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

        </main>
    </div>
</div>
