<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechShop Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-layout">

        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-brand">
                <i class="bi bi-cpu-fill"></i>
                <div>
                    <span>TechShop</span>
                    <small>Admin Panel</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                <div class="nav-section-label">Sản phẩm</div>

                <a asp-controller="AdminProduct" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("AdminProduct") ? "active" : "")">
                    <i class="bi bi-box"></i><span>Sản phẩm</span>
                </a>

                <a asp-controller="AdminCategory" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("AdminCategory") ? "active" : "")">
                    <i class="bi bi-tags"></i><span>Danh mục</span>
                </a>

                <div class="nav-section-label">Bán hàng</div>

                <a asp-controller="AdminOrder" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("AdminOrder") ? "active" : "")">
                    <i class="bi bi-receipt"></i><span>Đơn hàng</span>
                </a>

                <div class="nav-section-label">Hệ thống</div>

                <a asp-controller="AdminUser" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("AdminUser") ? "active" : "")">
                    <i class="bi bi-people"></i><span>Người dùng</span>
                </a>

                <a asp-controller="AdminRole" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("AdminRole") ? "active" : "")">
                    <i class="bi bi-shield-lock"></i><span>Phân quyền</span>
                </a>

                <div class="nav-section-label">Điều hướng</div>

                <a asp-controller="Home" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-shop"></i><span>Về trang chủ</span>
                </a>

                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-1">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link w-100 border-0 bg-transparent text-start text-danger">
                        <i class="bi bi-box-arrow-right"></i><span>Đăng xuất</span>
                    </button>
                </form>
            </nav>
        </aside>

        <!-- Main -->
        <div class="admin-main" id="adminMain">
            <header class="admin-topbar">
                <button class="sidebar-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-user">
                    <i class="bi bi-person-circle me-2"></i>
                    <span>@User.Identity!.Name?.Split('@')[0]</span>
                    <span class="badge bg-danger ms-2">Admin</span>
                </div>
            </header>

            <div class="admin-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
        var sidebar = document.getElementById('adminSidebar');
        var main = document.getElementById('adminMain');
        if (window.innerWidth <= 992) {
        sidebar.classList.toggle('mobile-open');
        } else {
        sidebar.classList.toggle('collapsed');
        main.style.marginLeft = sidebar.classList.contains('collapsed') ? '60px' : '240px';
        }
        }

        // Auto dismiss alerts
        setTimeout(function () {
        var alerts = document.querySelectorAll('.alert');
        alerts.forEach(function (a) {
        var bsAlert = bootstrap.Alert.getOrCreateInstance(a);
        bsAlert.close();
        });
        }, 4000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
