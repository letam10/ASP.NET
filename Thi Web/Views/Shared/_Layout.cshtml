@using Microsoft.AspNetCore.Identity
@inject UserManager<TechShop.Models.ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechShop</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/sidebar.css" asp-append-version="true" />
    @* <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script> *@
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-cpu-fill me-2"></i>TechShop
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navContent">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Wishlist">
                            <i class="bi bi-heart me-1"></i>Yêu thích
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Compare">
                            <i class="bi bi-bar-chart me-1"></i>So sánh
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Service" asp-action="Booking">
                            <i class="bi bi-tools me-1"></i>Dịch vụ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning fw-bold" asp-controller="Game" asp-action="LuckyWheel">
                            <i class="bi bi-controller me-1"></i>Minigame
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock me-1"></i>Quản trị
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li>
                                    <a class="dropdown-item" asp-controller="AdminProduct" asp-action="Index">
                                        <i class="bi bi-box me-2"></i>Sản phẩm
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="AdminCategory" asp-action="Index">
                                        <i class="bi bi-tags me-2"></i>Danh mục
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="AdminOrder" asp-action="Index">
                                        <i class="bi bi-receipt me-2"></i>Đơn hàng
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="AdminService" asp-action="Index">
                                        <i class="bi bi-tools me-2"></i>Phiếu dịch vụ
                                    </a>
                                </li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" href="https://tawk.to/chat/69bac14ebb7f0b1c337b2b54/1jk0o67bd" target="_blank" rel="noopener">
                                            <i class="bi bi-chat-dots me-2"></i>Chat khách hàng
                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item" asp-controller="AdminUser" asp-action="Index">
                                            <i class="bi bi-people me-2"></i>Người dùng
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="AdminRole" asp-action="Index">
                                            <i class="bi bi-key me-2"></i>Phân quyền
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item me-2">
                        <a class="nav-link cart-icon" asp-controller="Cart" asp-action="Index">
                            <i class="bi bi-cart3"></i>
                            @{
                                var cart = Context.Session.GetString("Cart");
                                int count = 0;
                                if (cart != null)
                                {
                                    var items = System.Text.Json.JsonSerializer.Deserialize<List<TechShop.Models.CartItem>>(cart);
                                    count = items?.Count ?? 0;
                                }
                            }
                            @if (count > 0)
                            {
                                <span class="cart-badge">@count</span>
                            }
                        </a>
                    </li>
                    <!-- Account -->
                    @if (User.Identity!.IsAuthenticated)
                    {
                        var user = await UserManager.GetUserAsync(User);
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name?.Split('@')[0]
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-person-badge me-2"></i>Hồ sơ cá nhân
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="badge bg-warning text-dark fs-6">
                                        <i class="bi bi-star-fill"></i> @(user?.LoyaltyPoints ?? 0) Điểm (@(user?.MembershipTier ?? "Bronze"))
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Order" asp-action="MyOrders">
                                        <i class="bi bi-clock-history me-2"></i>Đơn hàng của tôi
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm ms-2" asp-controller="Account" asp-action="Register">
                                Đăng ký
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Toast notification -->
    @if (TempData["Success"] != null)
{
    <div class="toast-container position-fixed top-0 end-0 p-3" style="margin-top:70px;z-index:9999">
        <div id="successToast" class="toast align-items-center text-bg-success border-0" role="alert"
             data-bs-autohide="true" data-bs-delay="1500">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>
}

    <!-- Main content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h5><i class="bi bi-cpu-fill me-2"></i>TechShop</h5>
                    <p class="text-muted">Cửa hàng công nghệ uy tín hàng đầu Việt Nam. Chất lượng cao, giá tốt nhất.</p>
                    <div class="social-links">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-6 mb-4">
                    <h6>Sản phẩm</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Laptop</a></li>
                        <li><a href="#">Chuột</a></li>
                        <li><a href="#">Bàn phím</a></li>
                        <li><a href="#">Màn hình</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6 mb-4">
                    <h6>Hỗ trợ</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Chính sách đổi trả</a></li>
                        <li><a href="#">Bảo hành</a></li>
                        <li><a href="#">Vận chuyển</a></li>
                        <li><a href="#">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 mb-4">
                    <h6>Liên hệ</h6>
                    <p class="text-muted"><i class="bi bi-geo-alt me-2"></i>123 Nguyễn Huệ, Q.1, TP.HCM</p>
                    <p class="text-muted"><i class="bi bi-telephone me-2"></i>1800 6789</p>
                    <p class="text-muted"><i class="bi bi-envelope me-2"></i>support@techshop.vn</p>
                </div>
            </div>
            <hr class="border-secondary">
            <p class="text-center text-muted mb-0">© 2025 TechShop. All rights reserved.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleWishlist(productId, btn) {
            $.ajax({
                url: '/Product/ToggleWishlist',
                type: 'POST',
                data: {
                    productId: productId,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').first().val()
                },
                success: function (res) {
                    if (!res.success) {
                        if (res.redirectUrl) {
                            window.location.href = res.redirectUrl;
                            return;
                        }
                        alert(res.message);
                        return;
                    }
                    btn.classList.toggle('active', res.isAdded);
                    const icon = btn.querySelector('i');
                    if (icon) {
                        icon.classList.toggle('bi-heart', !res.isAdded);
                        icon.classList.toggle('bi-heart-fill', res.isAdded);
                    }
                },
                error: function () {
                    alert('Có lỗi xảy ra khi thao tác yêu thích.');
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <!-- Tawk.to -->
    <script type="text/javascript">
        // visitor object phải có TRƯỚC embed
        window.Tawk_API = window.Tawk_API || {};
        window.Tawk_LoadStart = new Date();

        @if (User.Identity?.IsAuthenticated ?? false)
        {
                var u = await UserManager.GetUserAsync(User);
                <text>
                window.Tawk_API.visitor = {
                    name: '@(u?.FullName ?? User.Identity!.Name ?? "User")',
                    email: '@(u?.Email ?? "")'
                };
                </text>
        }
    </script>
    <script type="text/javascript">
        (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true;
            s1.src='https://embed.tawk.to/69bac14ebb7f0b1c337b2b54/1jk0o67bd';
            s1.charset='UTF-8';
            s1.setAttribute('crossorigin','*');
            s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
    <form id="global-anti-forgery-form" style="display:none;">
        @Html.AntiForgeryToken()
    </form>
</body>
</html>