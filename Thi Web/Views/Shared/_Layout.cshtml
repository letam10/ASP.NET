        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h5><i class="bi bi-cpu-fill me-2"></i>TechShop</h5>
                    <p class="text-muted">Cửa hàng công nghệ uy tín hàng đầu Việt Nam. Chất lượng cao, giá tốt nhất.</p>
                    <div class="social-links">
                        <a href="https://facebook.com" target="_blank" rel="noopener"><i class="bi bi-facebook"></i></a>
                        <a href="https://youtube.com" target="_blank" rel="noopener"><i class="bi bi-youtube"></i></a>
                        <a href="https://instagram.com" target="_blank" rel="noopener"><i class="bi bi-instagram"></i></a>
                        <a href="https://tiktok.com" target="_blank" rel="noopener"><i class="bi bi-tiktok"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-6 mb-4">
                    <h6>Sản phẩm</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a href="#">Laptop</a></li>
                        <li><a href="#">Chuột</a></li>
                        <li><a href="#">Bàn phím</a></li>
                        <li><a href="#">Màn hình</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-6 mb-4">
                    <h6>Hỗ trợ</h6>
                    <ul class="list-unstyled footer-links">
                        <li><a asp-controller="Home" asp-action="ChinhSach">Chính sách đổi trả</a></li>
                        <li><a asp-controller="Home" asp-action="ChinhSach">Bảo hành</a></li>
