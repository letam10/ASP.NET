                            <i class="bi bi-house me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-grid me-1"></i>Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Wishlist">
                            <i class="bi bi-heart me-1"></i>Yêu thích
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Compare">
                            <i class="bi bi-bar-chart me-1"></i>So sánh
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Service" asp-action="Booking">
                            <i class="bi bi-tools me-1"></i>Dịch vụ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-warning fw-bold" asp-controller="Game" asp-action="LuckyWheel">
                            <i class="bi bi-controller me-1"></i>Minigame
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
