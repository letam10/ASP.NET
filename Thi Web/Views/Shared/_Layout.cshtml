    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AOS.js Script -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Initialize AOS
        $(document).ready(function() {

            // Page Preloader Optimization
            const $preloader = $('#preloader');
            
            function hidePreloader() {
                if ($preloader.is(':visible')) {
                    $preloader.fadeOut(600, function() {
                        // Refresh AOS after preloader is completely gone
                        AOS.refresh();
                    });
                }
            }

            // Hide on DOM Ready
            hidePreloader();

            // Safety Timeout
            setTimeout(hidePreloader, 3000);

            // Show preloader on internal link clicks for smooth transition
            $(document).on('click', 'a', function(e) {
                const href = $(this).attr('href');
                const target = $(this).attr('target');
                
                if (e.isDefaultPrevented()) return;

                // Only trigger for internal links, not hashes, not target="_blank", and not special protocols
                if (href && 
                    href !== '#' && 
                    !href.startsWith('#') && 
                    !href.startsWith('javascript:') && 
                    !href.startsWith('mailto:') && 
                    !href.startsWith('tel:') &&
                    (!target || target === '_self')) {
                    
                    // Don't trigger for bootstrap toggles/dropdowns
                    if ($(this).data('bs-toggle') || $(this).hasClass('dropdown-toggle')) return;

                    $preloader.fadeIn(400);
                }
            });

            // Ripple Effect for Buttons
            $('.btn').on('mousedown', function(e) {
                const $btn = $(this);
                const $ripple = $('<span class="ripple"></span>');
                const offset = $btn.offset();
                const x = e.pageX - offset.left;
                const y = e.pageY - offset.top;

                $ripple.css({ top: y, left: x });
                $btn.append($ripple);

                setTimeout(() => $ripple.remove(), 600);
            });

            // Magic Cursor Follower
            if ($(window).width() > 991) {
                const $cursor = $('#magic-cursor');
                $(document).on('mousemove', function(e) {
                    $cursor.css({ left: e.clientX, top: e.clientY });
                });

                $(document).on('mousedown', () => $cursor.addClass('active'));
                $(document).on('mouseup', () => $cursor.removeClass('active'));

                $('a, button, .cat-card, .product-card').on('mouseenter', () => $cursor.addClass('hover'));
                $('a, button, .cat-card, .product-card').on('mouseleave', () => $cursor.removeClass('hover'));
            }
        });
        function getAntiForgeryToken() {
            return document.querySelector('#global-anti-forgery-form input[name="__RequestVerificationToken"]')?.value || '';
        }

        function toggleWishlist(productId, btn) {
            $.ajax({
                url: '/Product/ToggleWishlist',
                type: 'POST',
                data: {
                    productId: productId,
                    __RequestVerificationToken: getAntiForgeryToken()
                },
                success: function (res) {
                    if (!res.success) {
                        if (res.redirectUrl) {
                            window.location.href = res.redirectUrl;
                            return;
                        }
                        alert(res.message);
                        return;
                    }

                    if (btn) {
                        btn.classList.toggle('active', res.isAdded);

                        const icon = btn.querySelector('i');
                        if (icon) {
                            icon.classList.toggle('bi-heart', !res.isAdded);
                            icon.classList.toggle('bi-heart-fill', res.isAdded);
                        }
                        
                        // Refresh AOS if wishlist items change (might shift layout)
                        setTimeout(() => { AOS.refresh(); }, 300);
                    }
                },
                error: function () {
                    alert('Có lỗi xảy ra khi thao tác yêu thích.');
                }
            });
        }

        // Initialize AOS after all setup
        $(document).ready(function() {
            AOS.init({
                duration: 800,
                offset: 50, 
                once: true,
                easing: 'ease-out-cubic'
            });

            // Final refresh on window load to catch late content
            window.addEventListener('load', () => {
                setTimeout(() => { AOS.refresh(); }, 500);
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    <!-- Tawk.to -->
    <script type="text/javascript">
        // visitor object phải có TRƯỚC embed
        window.Tawk_API = window.Tawk_API || {};
        window.Tawk_LoadStart = new Date();

        @if (User.Identity?.IsAuthenticated ?? false)
        {
                var u = await UserManager.GetUserAsync(User);
                <text>
                window.Tawk_API.visitor = {
                    name: '@(u?.FullName ?? User.Identity!.Name ?? "User")',
                    email: '@(u?.Email ?? "")'
                };
                </text>
        }
    </script>
    <script type="text/javascript">
        (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true;
            s1.src='https://embed.tawk.to/69bac14ebb7f0b1c337b2b54/1jk0o67bd';
            s1.charset='UTF-8';
            s1.setAttribute('crossorigin','*');
            s0.parentNode.insertBefore(s1,s0);
        })();
    </script>
    <form id="global-anti-forgery-form" style="display:none;">
        @Html.AntiForgeryToken()
    </form>
</body>
</html>