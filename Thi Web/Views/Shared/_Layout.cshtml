                        <li><a asp-controller="Home" asp-action="GioiThieu">Liên hệ</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 mb-4">
                    <h6>Liên hệ</h6>
                    <p class="text-muted"><a asp-controller="Home" asp-action="GioiThieu"><i class="bi bi-geo-alt me-2"></i>123 Nguyễn Huệ, Q.1, TP.HCM</a></p>
                    <p class="text-muted"><a asp-controller="Home" asp-action="GioiThieu"><i class="bi bi-telephone me-2"></i>1800 6789</a></p>
                    <p class="text-muted"><a asp-controller="Home" asp-action="GioiThieu"><i class="bi bi-envelope me-2"></i>support@techshop.vn</a></p>
                </div>
