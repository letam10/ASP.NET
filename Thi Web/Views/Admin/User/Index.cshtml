@model List<TechShop.Models.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<div class="admin-page-header">
    <div>
        <h4 class="text-primary fw-bold"><i class="bi bi-people me-2"></i>Quản lý người dùng</h4>
        <p class="text-muted mb-0 small">Tổng cộng: <strong class="text-primary">@Model.Count</strong> tài khoản hệ thống</p>
    </div>
</div>

<div class="admin-table-wrap border-0 shadow-sm">
    <table class="admin-table">
        <thead>
            <tr>
                <th>Họ tên & Email</th>
                <th>Vai trò</th>
                <th>Điểm & Hạng thẻ</th>
                <th class="text-end">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-primary-subtle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; color: var(--primary);">
                                <i class="bi bi-person-fill fs-5"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-primary">@(user.FullName ?? "N/A")</div>
                                <small class="text-muted">@user.Email</small>
                            </div>
                        </div>
                    </td>
                    <td>
                        @if (userRoles!.ContainsKey(user.Id))
                        {
                            foreach (var role in userRoles[user.Id])
                            {
                                <span class="admin-badge @(role == "Admin" ? "danger" : "info") me-1">
                                    <i class="bi bi-shield-check me-1"></i>@role
                                </span>
                            }
                        }
                    </td>
                    <td>
                        <div class="d-flex flex-column gap-1">
                            <span class="admin-badge warning shadow-none w-fit">
                                <i class="bi bi-star-fill me-1"></i>@user.LoyaltyPoints <small class="ms-1 text-muted">điểm</small>
                            </span>
                            <span class="admin-badge success shadow-none w-fit">
                                <i class="bi bi-award me-1"></i>@user.MembershipTier
                            </span>
                        </div>
                    </td>
                    <td>
                        <div class="admin-actions">
                            <button class="btn-admin-action shadow-sm" data-bs-toggle="modal" 
                                    data-bs-target="#editLoyalty-@user.Id" title="Sửa Điểm/Thẻ">
                                <i class="bi bi-gem"></i>
                            </button>

                            <a asp-controller="AdminUser" asp-action="AssignRole" asp-route-userId="@user.Id"
                               class="btn-admin-action shadow-sm text-info" title="Phân quyền">
                                <i class="bi bi-key-fill"></i>
                            </a>

                            <form asp-controller="AdminUser" asp-action="Delete" method="post" class="m-0"
                                  onsubmit="return confirm('Bạn có chắc chắn muốn xóa người dùng này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="btn-admin-action delete shadow-sm" title="Xóa">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>

                <!-- Modal cập nhật điểm/thẻ -->
                <div class="modal fade" id="editLoyalty-@user.Id" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <form asp-action="UpdateLoyalty" method="post" class="modal-content border-0 shadow-lg bg-card">
                            @Html.AntiForgeryToken()
                            <div class="modal-header border-bottom border-light-subtle py-3">
                                <h5 class="modal-title fw-bold text-primary">
                                    <i class="bi bi-pencil-square me-2"></i>Cập nhật tài khoản
                                </h5>
                                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body p-4 text-start">
                                <p class="text-muted small mb-4">Điều chỉnh thông số thành viên cho <strong>@user.FullName</strong></p>
                                <input type="hidden" name="userId" value="@user.Id" />
                                
                                <div class="mb-4">
                                    <label class="form-label fw-bold">Điểm tích lũy (Loyalty Points)</label>
                                    <input type="number" name="points" class="form-control" value="@user.LoyaltyPoints" required min="0" />
                                </div>
                                
                                <div class="mb-2">
                                    <label class="form-label fw-bold">Hạng thành viên</label>
                                    <select name="tier" class="form-select">
                                        <option value="Bronze" selected="@(user.MembershipTier == "Bronze")">Bronze (Đồng)</option>
                                        <option value="Silver" selected="@(user.MembershipTier == "Silver")">Silver (Bạc)</option>
                                        <option value="Gold" selected="@(user.MembershipTier == "Gold")">Gold (Vàng)</option>
                                        <option value="Diamond" selected="@(user.MembershipTier == "Diamond")">Diamond (Kim cương)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="modal-footer border-top-0 p-4">
                                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-primary px-4 shadow-sm">Lưu thay đổi</button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </tbody>
    </table>
</div>