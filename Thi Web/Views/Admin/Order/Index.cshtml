@model List<TechShop.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<div class="admin-page-header">
    <div>
        <h4><i class="bi bi-receipt me-2"></i>Quản lý đơn hàng</h4>
        <p class="text-muted mb-0">Tổng @Model.Count đơn</p>
    </div>
</div>

<!-- ====== Thống kê ====== -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body">
                <h5>Tổng doanh thu</h5>
                <h3>@Model.Where(o => o.Status == "Đã giao").Sum(o => o.TotalAmount).ToString("N0") ₫</h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <h5>Đơn chờ xử lý</h5>
                <h3>@(Model.Count(o => o.Status == "Chờ xác nhận")) đơn</h3>
            </div>
        </div>
    </div>
</div>
<!-- ====================================== -->
<div class="admin-table-wrap">
    <table class="table admin-table">
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Ngày đặt</th><th>Tổng tiền</th><th>Trạng thái</th><th></th></tr></thead>
        <tbody>
            @foreach (var order in Model)
            {
                var cls = order.Status switch { "Completed" => "bg-success", "Cancelled" => "bg-danger", "Processing" => "bg-info", _ => "bg-warning" };
                <tr>
                    <td><strong>#@order.Id.ToString("D6")</strong></td>
                    <td>@(order.User?.FullName ?? order.User?.Email ?? "N/A")</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-primary fw-bold">@order.TotalAmount.ToString("N0") ₫</td>
                    <td><span class="badge @cls">@order.Status</span></td>
                    <td><a asp-controller="AdminOrder" asp-action="Detail" asp-route-id="@order.Id" class="btn btn-sm btn-primary"><i class="bi bi-eye"></i></a></td>
                </tr>
            }
        </tbody>
    </table>
</div>