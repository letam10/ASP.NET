@{
    ViewData["Title"] = "Tạo Role mới";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}
<div class="admin-page-header">
    <div><h4><i class="bi bi-plus-circle me-2"></i>Tạo Role mới</h4></div>
    <a asp-controller="AdminRole" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>
<div class="admin-form-card" style="max-width:400px">
    <form asp-controller="AdminRole" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="mb-4">
            <label class="form-label">Tên Role</label>
            <input type="text" name="roleName" class="form-control" placeholder="VD: Moderator..." required />
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Tạo Role</button>
            <a asp-controller="AdminRole" asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        </div>
    </form>
</div>