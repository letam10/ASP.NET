@model List<TechShop.Models.ServiceTicket>
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Dịch vụ & Bảo hành";
}

<div class="admin-page-header">
    <div>
        <h4 class="text-primary fw-bold"><i class="bi bi-wrench-adjustable me-2"></i>Phiếu dịch vụ & Bảo hành</h4>
        <p class="text-muted mb-0 small">Danh sách yêu cầu hỗ trợ kỹ thuật</p>
    </div>
</div>

<div class="admin-table-wrap border-0 shadow-sm">
    <table class="admin-table">
        <thead>
            <tr>
                <th style="width: 80px;">Mã</th>
                <th>Khách hàng</th>
                <th>Thiết bị / Model</th>
                <th>Loại yêu cầu</th>
                <th>Ngày hẹn</th>
                <th>Trạng thái</th>
                <th class="text-end">Cập nhật</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                var badgeClass = t.Status switch
                {
                    "Pending" => "warning",
                    "InProgress" => "info",
                    "Completed" => "success",
                    _ => "danger"
                };
                var statusText = t.Status switch
                {
                    "Pending" => "Chờ xác nhận",
                    "InProgress" => "Đang sửa chữa",
                    "Completed" => "Hoàn thành",
                    _ => "Đã hủy"
                };
                <tr>
                    <td><code class="text-primary font-monospace">#@t.Id</code></td>
                    <td>
                        <div class="fw-bold text-dark">@t.CustomerName</div>
                        <small class="text-muted"><i class="bi bi-telephone me-1"></i>@t.PhoneNumber</small>
                    </td>
                    <td>@t.DeviceModel</td>
                    <td>
                        <span class="admin-badge info shadow-none">@t.ServiceType</span>
                    </td>
                    <td class="small">@t.BookingDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <span class="admin-badge @badgeClass">@statusText</span>
                    </td>
                    <td class="text-end">
                        <form asp-action="UpdateStatus" method="post" class="d-inline-block">
                            <input type="hidden" name="id" value="@t.Id" />
                            <select name="status" class="form-select form-select-sm border-primary-subtle shadow-sm" style="width: 140px;" onchange="this.form.submit()">
                                <option value="">-- Cập nhật --</option>
                                <option value="Pending">Chờ xác nhận</option>
                                <option value="InProgress">Đang sửa chữa</option>
                                <option value="Completed">Hoàn thành</option>
                                <option value="Cancelled">Hủy</option>
                            </select>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>