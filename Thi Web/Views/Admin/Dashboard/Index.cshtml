@model TechShop.ViewModels.Admin.AdminDashboardViewModel
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="admin-page-header">
    <div>
        <h4 class="text-primary fw-bold"><i class="bi bi-speedometer2 me-2"></i>Tổng quan hệ thống</h4>
        <p class="text-muted mb-0 small">Dữ liệu cập nhật theo thời gian thực</p>
    </div>
</div>

<!-- ====== Thống kê nhanh ====== -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card shadow-sm border-0">
            <div class="stat-card-icon green shadow-sm">
                <i class="bi bi-currency-dollar"></i>
            </div>
            <div class="stat-card-body">
                <p>Tổng doanh thu</p>
                <h3>@Model.TotalRevenue.ToString("N0") <small class="fs-6">₫</small></h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card shadow-sm border-0">
            <div class="stat-card-icon blue shadow-sm">
                <i class="bi bi-cart-check"></i>
            </div>
            <div class="stat-card-body">
                <p>Tổng đơn hàng</p>
                <h3>@Model.TotalOrders <small class="fs-6">đơn</small></h3>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="stat-card shadow-sm border-0">
            <div class="stat-card-icon amber shadow-sm">
                <i class="bi bi-box-seam"></i>
            </div>
            <div class="stat-card-body">
                <p>Tổng sản phẩm</p>
                <h3>@Model.TotalProducts <small class="fs-6">mặt hàng</small></h3>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Sản phẩm bán chạy -->
    <div class="col-lg-7">
        <div class="admin-table-wrap border-0 shadow-sm p-4 h-100">
            <h5 class="text-primary fw-bold mb-4"><i class="bi bi-award me-2"></i>Sản phẩm bán chạy nhất</h5>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Tên sản phẩm</th>
                        <th class="text-center">Số lượng đã bán</th>
                        <th class="text-end">Doanh thu</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.TopProducts)
                    {
                        <tr>
                            <td>
                                <div class="fw-bold">@p.ProductName</div>
                            </td>
                            <td class="text-center">
                                <span class="admin-badge info">@p.SoldQuantity</span>
                            </td>
                            <td class="text-end fw-bold text-success">
                                @p.Revenue.ToString("N0") ₫
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Biểu đồ tỷ lệ -->
    <div class="col-lg-5">
        <div class="admin-table-wrap border-0 shadow-sm p-4 h-100">
            <h5 class="text-primary fw-bold mb-4"><i class="bi bi-pie-chart me-2"></i>Tỷ lệ bán hàng</h5>
            <div style="max-height: 350px;">
                <canvas id="salesRatioChart"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesRatio.Select(x => x.ProductName)));
        const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesRatio.Select(x => x.SoldQuantity)));

        new Chart(document.getElementById('salesRatioChart'), {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: data,
                    backgroundColor: [
                        '#6366f1', '#10b981', '#f59e0b', '#ef4444', '#3b82f6', '#8b5cf6'
                    ],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            usePointStyle: true,
                            padding: 20,
                            color: '#94a3b8'
                        }
                    }
                },
                cutout: '70%'
            }
        });
    </script>
}