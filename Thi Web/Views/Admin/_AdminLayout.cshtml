<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechShop Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-layout">
        <!-- Sidebar -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <i class="bi bi-cpu-fill"></i>
                <span>TechShop</span>
                <small>Admin Panel</small>
            </div>

            <nav class="sidebar-nav">
                @if (User.IsInRole("Admin"))
                {
                    <div class="nav-section-label">Sản phẩm</div>
                    <a href="/Admin/AdminProduct/Index" class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/AdminProduct") ? "active" : "")">
                        <i class="bi bi-box"></i><span>Sản phẩm</span>
                    </a>
                    <a href="/Admin/AdminCategory/Index" class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/AdminCategory") ? "active" : "")">
                        <i class="bi bi-tags"></i><span>Danh mục</span>
                    </a>
                    <div class="nav-section-label">Bán hàng</div>
                    <a href="/Admin/AdminOrder/Index" class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/AdminOrder") ? "active" : "")">
                        <i class="bi bi-receipt"></i><span>Đơn hàng</span>
                    </a>
                    <a asp-controller="AdminService" asp-action="Index" class="sidebar-link">
                        <i class="bi bi-wrench-adjustable"></i><span>Phiếu dịch vụ</span>
                    </a>
                    <div class="nav-section-label">Hệ thống</div>
                    <a href="https://dashboard.tawk.to/" target="_blank" rel="noopener">
                        <i class="bi bi-chat-dots me-2"></i>Chat khách hàng (Tawk.to)
                    </a>

                    <a href="/Admin/AdminUser/Index" class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/AdminUser") ? "active" : "")">
                        <i class="bi bi-people"></i><span>Người dùng</span>
                    </a>
                    <a href="/Admin/AdminRole/Index" class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Admin/AdminRole") ? "active" : "")">
                        <i class="bi bi-shield-lock"></i><span>Phân quyền</span>
                    </a>
                }

                <div class="nav-section-label">Điều hướng</div>
                <a href="/" class="sidebar-link">
                    <i class="bi bi-shop"></i><span>Về trang chủ</span>
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-2">
                    <button type="submit" class="sidebar-link w-100 border-0 bg-transparent text-start text-danger">
                        <i class="bi bi-box-arrow-right"></i><span>Đăng xuất</span>
                    </button>
                </form>
            </nav>
        </aside>

        <!-- Main content -->
        <div class="admin-main">
            <header class="admin-topbar">
                <button class="sidebar-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <div class="topbar-title">@ViewData["Title"]</div>
                <div class="topbar-user">
                    <i class="bi bi-person-circle me-2"></i>
                    <span>@User.Identity!.Name?.Split('@')[0]</span>
                    <span class="badge bg-danger ms-2">Admin</span>
                </div>
            </header>
            <div class="admin-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
        document.querySelector('.admin-sidebar').classList.toggle('collapsed');
        }
        // Auto-dismiss toasts
        document.querySelectorAll('.toast').forEach(t => {
        setTimeout(() => t.classList.remove('show'), 4000);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
