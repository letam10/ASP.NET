@model TechShop.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    var categories = ViewBag.Categories as List<TechShop.Models.Category>;
}
<div class="admin-page-header">
    <div><h4>Chỉnh sửa sản phẩm</h4></div>
    <a asp-controller="AdminProduct" asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>
<div class="admin-form-card">
    <form asp-controller="AdminProduct" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="row g-3">
            <div class="col-md-8"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /></div>
            <div class="col-md-4">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" class="form-select">
                    @foreach (var c in categories!)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
                    }
                </select>
                @{
                    var variantGroups = ViewBag.VariantGroups as List<TechShop.Models.ProductVariantGroup>;
                    var selectedOptionIds = ViewBag.SelectedOptionIds as List<int> ?? new();
                }
                <div id="variant-options-wrap" class="col-12">
                    <label class="form-label fw-bold">Biến thể đang có</label>

                    @if (variantGroups != null)
                    {
                        foreach (var group in variantGroups)
                        {
                            <div class="variant-group-block mb-3" data-category-id="@group.CategoryId">
                                <div class="fw-bold mb-2">@group.Name</div>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var opt in group.Options.Where(x => x.IsActive).OrderBy(x => x.SortOrder))
                                    {
                                        bool isChecked = selectedOptionIds.Contains(opt.Id);
                                        <label class="btn @(isChecked ? "btn-primary" : "btn-outline-secondary") rounded-pill px-3">
                                            <input type="checkbox" name="selectedOptionIds" value="@opt.Id" class="d-none" @(isChecked ? "checked" : "") />
                                            @opt.Value
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="col-md-6"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" /></div>
            <div class="col-md-3"><label asp-for="Stock" class="form-label"></label><input asp-for="Stock" class="form-control" /></div>
            <div class="col-md-3"><label class="form-label">Trạng thái</label><div class="form-check mt-2"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label">Hiển thị</label></div></div>
            <div class="col-12">
                <label asp-for="ImageUrl" class="form-label fw-bold"></label>
                <div class="input-group">
                    <input asp-for="ImageUrl" class="form-control" id="product-image-url" placeholder="Dán link hình ảnh vào đây..." />
                    <span class="input-group-text bg-success text-white d-none" id="save-indicator" style="transition: all 0.3s ease;">
                        <i class="bi bi-check-all me-1"></i>Đã lưu
                    </span>
                </div>
                <div class="mt-3 p-3 border rounded text-center bg-dark-subtle" style="min-height: 120px; position: relative; border-style: dashed !important;">
                    <img id="product-image-preview" src="@Model.ImageUrl" alt="Preview" 
                         class="img-fluid rounded shadow-sm"
                         style="max-height: 250px; @(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")" 
                         onerror="this.style.display='none'; document.getElementById('image-placeholder').style.display='block';" />
                    <div id="image-placeholder" class="py-4" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "" : "display:none;")">
                        <i class="bi bi-card-image text-secondary opacity-50" style="font-size: 3rem;"></i>
                        <p class="text-secondary mb-0">Chưa có ảnh hoặc link lỗi</p>
                    </div>
                    <div id="sync-spinner" class="position-absolute top-50 start-50 translate-middle d-none text-primary">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                    </div>
                </div>
            </div>
            <div class="col-12"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
        </div>
        <div class="mt-4"><button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Lưu thay đổi</button></div>
    </form>
</div>
@section Scripts {
    <script>
        (function () {
            const categorySelect = document.querySelector('select[name="CategoryId"]');
            const blocks = document.querySelectorAll('.variant-group-block');

            function filterBlocks() {
                const categoryId = categorySelect.value;
                blocks.forEach(block => {
                    block.style.display = block.dataset.categoryId === categoryId ? '' : 'none';

                    if (block.dataset.categoryId !== categoryId) {
                        block.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);
                        block.querySelectorAll('label.btn').forEach(lb => lb.classList.remove('btn-primary'));
                    }
                });
            }

            document.querySelectorAll('.variant-group-block label.btn').forEach(label => {
                label.addEventListener('click', function () {
                    setTimeout(() => {
                        const cb = label.querySelector('input[type="checkbox"]');
                        label.classList.toggle('btn-primary', cb.checked);
                    }, 0);
                });
            });

            categorySelect.addEventListener('change', filterBlocks);
            filterBlocks();

            // Real-time Image Sync Logic
            const imgInput = document.getElementById('product-image-url');
            const imgPreview = document.getElementById('product-image-preview');
            const imgPlaceholder = document.getElementById('image-placeholder');
            const saveIndicator = document.getElementById('save-indicator');
            const syncSpinner = document.getElementById('sync-spinner');
            const productId = '@Model.Id';

            function updateSync(url) {
                if (!url) {
                    imgPreview.style.display = 'none';
                    imgPlaceholder.style.display = 'block';
                } else {
                    imgPreview.src = url;
                    imgPreview.style.display = 'block';
                    imgPlaceholder.style.display = 'none';
                }

                // Call AJAX to update DB immediately
                syncSpinner.classList.remove('d-none');
                
                const formData = new FormData();
                formData.append('productId', productId);
                formData.append('imageUrl', url);
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                fetch('/Admin/Product/UpdateImageUrl', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    syncSpinner.classList.add('d-none');
                    if (data.success) {
                        saveIndicator.classList.remove('d-none');
                        setTimeout(() => {
                            saveIndicator.classList.add('d-none');
                        }, 2000);
                    } else {
                        console.error('Lỗi khi lưu ảnh:', data.message);
                    }
                })
                .catch(error => {
                    syncSpinner.classList.add('d-none');
                    console.error('Network error:', error);
                });
            }

            imgInput.addEventListener('change', function() {
                updateSync(this.value.trim());
            });

            // Debounce paste event
            imgInput.addEventListener('paste', function() {
                setTimeout(() => updateSync(this.value.trim()), 50);
            });
        })();
    </script>
}