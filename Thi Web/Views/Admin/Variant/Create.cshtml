@section Scripts {
    <script>
        (function () {
            const productSelect = document.querySelector('select[name="ProductId"]');
            if (!productSelect) return;

            function filterOptionsByCategory() {
                const selected = productSelect.options[productSelect.selectedIndex];
                const categoryId = selected?.dataset?.categoryId;
                const optionItems = document.querySelectorAll('.option-item');

                optionItems.forEach(item => {
                    const allowedIds = (item.getAttribute('data-category-ids') || '')
                        .split(',')
                        .map(x => x.trim())
                        .filter(Boolean);
                    const checkbox = item.querySelector('input[type="checkbox"]');
                    const isAllowed = !categoryId || allowedIds.length === 0 || allowedIds.includes(categoryId);

                    item.style.display = isAllowed ? '' : 'none';
                    if (!isAllowed && checkbox) checkbox.checked = false;
                });
            }

            productSelect.addEventListener('change', filterOptionsByCategory);
            filterOptionsByCategory();
        })();
    </script>
} *@