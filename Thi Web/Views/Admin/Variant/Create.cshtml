                <label class="form-label">Thuộc tính biến thể</label>
                <div class="row">
                    @foreach (var o in options ?? new())
                    {
                        var categoryIds = optionCategoryMap.TryGetValue(o.Id, out var ids) ? ids : new List<int>();
                        <div class="col-md-4 mb-2">
                            <label class="form-check option-item" data-category-ids="@string.Join(",", categoryIds)">
                                <input type="checkbox" name="selectedOptionIds" value="@o.Id" class="form-check-input" />
                                <span class="form-check-label">
